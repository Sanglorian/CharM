<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- UIDeviceFamily 2 = iPad — the required value for Mac Catalyst apps. -->
    <key>UIDeviceFamily</key>
    <array>
        <integer>2</integer>
    </array>
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.role-playing-games</string>
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>arm64</string>
    </array>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>XSAppIconAssets</key>
    <string>Assets.xcassets/appicon.appiconset</string>
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
    <!-- Workaround for dotnet/maui#33294: on Mac Catalyst 16+/.NET 10 the
         new effectiveGeometry-driven UIKit layout pass can deadlock during
         BlazorWebView content changes (symptom: app locks up on "Create
         Character" or other state transitions that swap large bound
         subtrees). Opting in to UIKit's "design compatibility" mode
         disables the new layout engine and avoids the hang. Remove once
         the underlying MAUI/UIKit issue is fixed. -->
    <key>UIDesignRequiresCompatibility</key>
    <true/>
</dict>
</plist>
