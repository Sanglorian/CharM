@using CharM.Engine.Creation
@using CharM.Web.Services
@inject CharacterSessionService SessionService

@if (SessionService.Session is { HouseruleGrants.Count: > 0 } session)
{
    <div class="mt-3 border-t border-outline-variant/10 pt-3 space-y-1.5">
        <div class="text-[10px] font-label font-bold uppercase tracking-widest text-outline">Houserules</div>
        @foreach (var grant in session.HouseruleGrants.OrderBy(g => g.AtLevel).ThenBy(g => g.Element.Name, StringComparer.OrdinalIgnoreCase))
        {
            <div class="group flex items-center justify-between gap-3 border-b border-outline-variant/10 pb-1.5">
                <div class="min-w-0">
                    <div class="text-sm font-bold truncate">
                        @grant.Element.Name
                        <HouseruleBadge />
                    </div>
                    <div class="text-[10px] text-outline uppercase tracking-wider">
                        @FormatGrantKind(grant)
                    </div>
                </div>
                <button @onclick="() => Remove(grant)"
                        class="opacity-0 group-hover:opacity-100 transition-opacity p-1 rounded hover:bg-error-container/20 text-error no-print"
                        title="Remove houserule">
                    <span class="material-symbols-outlined text-base">delete</span>
                </button>
            </div>
        }
    </div>
}

@code {
    private static string FormatGrantKind(HouseruleGrant grant)
        => grant.Kind switch
        {
            HouseruleGrantKind.RulesElement => $"{grant.Element.Type} - level {grant.AtLevel}",
            HouseruleGrantKind.Inventory => $"{grant.Element.Type} - inventory x{grant.Quantity}",
            HouseruleGrantKind.Equipment => $"{grant.Element.Type} - equipped: {grant.Slot}",
            _ => grant.Element.Type,
        };

    private void Remove(HouseruleGrant grant)
    {
        SessionService.RemoveHouseruleGrant(grant.Element.InternalId, grant.Kind, grant.Slot);
    }
}
