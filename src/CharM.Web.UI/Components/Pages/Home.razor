                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Magic Item Builder Modal -->
    <MagicItemBuilderModal Visible="_showMagicBuilder"
                           PreselectedBase="_magicBuilderPreselectedBase"
                           TargetSlot="@_magicBuilderTargetSlot"
                           AllowStandalonePath="_magicBuilderPreselectedBase is null"
                           OnConfirm="ConfirmMagicComposite"
                           OnClose="CloseMagicBuilder" />
}

@code {
    private string _characterName = "";
    private int _level = 1;
    private bool _showModal;
    private PendingChoice? _activeChoice;
    private IReadOnlyList<RulesElement>? _modalCandidates;
    private int _lastAutoResolveChoiceCount = -1;
    private int _lastAutoResolvePendingCount = -1;
    private bool _lastAutoResolveScoresSet;
    private bool _showCompleteToast;
    private bool _lastCompleteState;
    private CancellationTokenSource? _completeToastCts;

    // Inline-edit state for header identity
    private bool _editingName;
    private bool _editingLevel;
    private bool _editingXp;
    private bool _editingAbilityScores;

    // Gameplay resource tracking
    private int _actionPoints = 1;

    // Alignment editing
    private bool _editingAlignment;
    private static readonly string[] _alignments = ["Lawful Good", "Good", "Unaligned", "Evil", "Chaotic Evil"];

    // Equipment browser state
    private bool _showEquipmentModal;
    private string? _activeEquipSlot;
    private IReadOnlyList<RulesElement>? _equipmentCandidates;

    // Magic Item builder state
    private bool _showMagicBuilder;
    private RulesElement? _magicBuilderPreselectedBase;
    private string? _magicBuilderTargetSlot;
    private string _equipSearchText = "";
    private RulesElement? _selectedEquipItem;
    private RulesElement? _selectedEquipDetail;
    private bool _equipOnlyProficient;
    private string _equipSortMode = "level";

    private static readonly string[] _equipSlots =
        ["Main Hand", "Off-Hand", "Chest", "Head", "Neck", "Arms", "Hands", "Waist", "Feet", "Ring 1", "Ring 2"];

    private static readonly (string Name, Ability Key)[] _abilityDefs =
    [
        ("Strength", Ability.Strength),
        ("Constitution", Ability.Constitution),
        ("Dexterity", Ability.Dexterity),
        ("Intelligence", Ability.Intelligence),
        ("Wisdom", Ability.Wisdom),
        ("Charisma", Ability.Charisma),
    ];

    private static readonly Dictionary<string, string[]> _abilityToSkills = new(StringComparer.OrdinalIgnoreCase)
    {
        ["Strength"] = ["Athletics"],
        ["Constitution"] = ["Endurance"],
        ["Dexterity"] = ["Acrobatics", "Stealth", "Thievery"],
        ["Intelligence"] = ["Arcana", "History", "Religion"],
        ["Wisdom"] = ["Dungeoneering", "Heal", "Insight", "Nature", "Perception"],
        ["Charisma"] = ["Bluff", "Diplomacy", "Intimidate", "Streetwise"],
    };

    protected override void OnInitialized()
    {
        SessionService.Changed += HandleSessionChanged;
        RestoreState.Changed += HandleSessionChanged;
        UpdateCompleteToast(SessionService.Session?.IsComplete == true);
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        var session = SessionService.Session;
        if (session is null)
            return Task.CompletedTask;

        var pendingChoices = session.GetAllPendingChoices();
        EnsureAutoResolved(session, ref pendingChoices);
        return Task.CompletedTask;
    }

    private void StartNewCharacter()
    {
        var session = SessionService.NewCharacter(_level);
        session.Name = string.IsNullOrWhiteSpace(_characterName) ? "New Character" : _characterName;
        // Mirror Name into TextStrings so the exporter emits the OCB-style
        // <textstring name="Name"> alongside <Details><name>. The exporter
        // only re-emits Name when it's already in TextStrings (see
        // Dnd4eExporter.cs notes), so we have to seed it here.
        SessionService.SetTextString("Name", session.Name);
        _lastAutoResolveChoiceCount = -1;
        _lastAutoResolvePendingCount = -1;
        _lastAutoResolveScoresSet = false;
        UpdateCompleteToast(false);
    }

    private void OpenSelectionModal(PendingChoice choice)
    {
        // Ability scores don't use the modal — scroll to the score entry instead
        if (choice.Slot.ElementType.Equals("Ability Scores", StringComparison.OrdinalIgnoreCase))
            return;

        _activeChoice = choice;
        _modalCandidates = SessionService.Session!.GetCandidatesForSlot(choice.Slot);
        _showModal = true;
    }

    private void OnElementSelected(RulesElement element)
    {
        if (_activeChoice is null) return;

        // If this is an Alignment choice, also sync to the Details dictionary
        if (_activeChoice.Slot.ElementType.Equals("Alignment", StringComparison.OrdinalIgnoreCase))
        {
            SessionService.SetDetailField("Alignment", element.Name);
        }

        SessionService.Session!.MakeChoice(_activeChoice.Slot, element);
        CloseModal();
    }

    private void CloseModal()
    {
        _showModal = false;
        _activeChoice = null;
        _modalCandidates = null;
    }

    // View-details modal (read-only) for already-selected features/feats/traits/choices
    private RulesElement? _detailModalElement;

    private void OpenDetailModal(string internalId)
    {
        _detailModalElement = SessionService.GetElementDetails(internalId);
    }

    private bool IsHouseruledElement(string? internalId)
        => SessionService.Session?.IsHouseruledElement(internalId) == true;

    private void CloseDetailModal()
    {
        _detailModalElement = null;
    }

    private RulesElement? LoadElementDetails(string internalId)
        => SessionService.GetElementDetails(internalId);

    private List<CharM.Web.Services.ResolvedElement> ResolveElementIds(string idList)
        => SessionService.ResolveElementIds(idList);

    private void OnAbilityScoresSet(AbilityScoreSet scores)
    {
        SessionService.Session!.SetAbilityScores(scores);
    }

    private void OnAbilityScoresEdited(AbilityScoreSet scores)
    {
        SessionService.Session!.SetAbilityScores(scores);
        _editingAbilityScores = false;
    }

    private string CurrentXp
        => SessionService.Session?.Details.GetValueOrDefault("Experience") is { Length: > 0 } v
            ? v
            : "0";

    private static int XpForNextLevel(int level)
    {
        // 4e XP thresholds (cumulative XP to reach each level, levels 1..30)
        // Index 0 unused; "next level" returns threshold for level+1, capped at 30.
        int next = Math.Min(level + 1, 30);
        return next switch
        {
            <= 1 => 0,
            2 => 1000, 3 => 2250, 4 => 3750, 5 => 5500, 6 => 7500, 7 => 10000,
            8 => 13000, 9 => 16500, 10 => 20500, 11 => 26000, 12 => 32000,
            13 => 39000, 14 => 47000, 15 => 57000, 16 => 69000, 17 => 83000,
            18 => 99000, 19 => 119000, 20 => 143000, 21 => 175000, 22 => 210000,
            23 => 255000, 24 => 310000, 25 => 375000, 26 => 450000, 27 => 550000,
            28 => 675000, 29 => 825000, 30 => 1000000,
            _ => 1000000,
        };
    }

    private static int XpProgressPercent(CharacterSession session)
    {
        if (!int.TryParse(session.Details.GetValueOrDefault("Experience"), out var xp) || xp <= 0)
            return 0;
        var target = XpForNextLevel(session.Level);
        if (target <= 0) return 100;
        var pct = (int)Math.Round(100.0 * xp / target);
        return Math.Clamp(pct, 0, 100);
    }

    private void CommitName(string? value)
    {
        var s = SessionService.Session;
        if (s is not null && !string.IsNullOrWhiteSpace(value))
        {
            s.Name = value.Trim();
            SessionService.SetTextString("Name", s.Name);
        }
        _editingName = false;
    }

    private void CommitLevel(string? value)
    {
        var s = SessionService.Session;
        if (s is not null && int.TryParse(value, out var lvl))
        {
            lvl = Math.Clamp(lvl, 1, 30);
            if (lvl != s.Level)
                s.SetLevel(lvl);
        }
        _editingLevel = false;
    }

    private void CommitXp(string? value)
    {
        var s = SessionService.Session;
        if (s is not null)
        {
            if (int.TryParse(value, out var xp) && xp >= 0)
                SessionService.SetDetailField("Experience", xp.ToString());
            else if (string.IsNullOrWhiteSpace(value))
                SessionService.SetDetailField("Experience", "0");
        }
        _editingXp = false;
    }

    private void IncrementActionPoints() => _actionPoints++;
    private void DecrementActionPoints() { if (_actionPoints > 0) _actionPoints--; }

    private static string FormatTacticalStat(string statName, int val)
    {
        if (statName == "Speed") return $"{val} sq";
        if (statName.StartsWith("Passive", StringComparison.Ordinal)) return $"{val}";
        return val >= 0 ? $"+{val}" : $"{val}";
    }

    private void CommitAlignment(string? value)
    {
        var s = SessionService.Session;
        if (s is null || string.IsNullOrWhiteSpace(value))
        {
            _editingAlignment = false;
            return;
        }

        SessionService.SetDetailField("Alignment", value);

        // Also resolve the Alignment choice slot in the wizard
        var pending = s.GetAllPendingChoices();
        var alignmentChoice = pending.FirstOrDefault(p =>
            p.Slot.ElementType.Equals("Alignment", StringComparison.OrdinalIgnoreCase));
        if (alignmentChoice is not null)
        {
            var candidates = s.GetCandidatesForSlot(alignmentChoice.Slot);
            var match = candidates.FirstOrDefault(c =>
                c.Name.Equals(value, StringComparison.OrdinalIgnoreCase));
            if (match is not null)
                s.MakeChoice(alignmentChoice.Slot, match);
        }

        _editingAlignment = false;
    }

    private void AutoResolveSingleOptions(CharacterSession session,
        ref IReadOnlyList<PendingChoice> pendingChoices)
    {
        // Loop because resolving one choice can cascade new single-option choices
        int maxPasses = 20;
        while (maxPasses-- > 0)
        {
            bool resolved = false;
            foreach (var choice in pendingChoices)
            {
                if (choice.Slot.Optional || IsSkippableType(choice.Slot.ElementType))
                    continue;
                if (choice.Slot.ElementType.Equals("Ability Scores", StringComparison.OrdinalIgnoreCase))
                    continue;

                var candidates = session.GetCandidatesForSlot(choice.Slot);
                if (candidates.Count == 1)
                {
                    session.MakeChoice(choice.Slot, candidates[0]);
                    resolved = true;
                    break; // pendingChoices is stale, re-fetch
                }
            }

            if (!resolved) break;
            pendingChoices = session.GetAllPendingChoices();
        }
    }

    private void EnsureAutoResolved(CharacterSession session,
        ref IReadOnlyList<PendingChoice> pendingChoices)
    {
        if (_lastAutoResolveChoiceCount == session.ChoiceHistory.Count
            && _lastAutoResolvePendingCount == pendingChoices.Count
            && _lastAutoResolveScoresSet == session.ScoresSet)
        {
            return;
        }

        AutoResolveSingleOptions(session, ref pendingChoices);
        _lastAutoResolveChoiceCount = session.ChoiceHistory.Count;
        _lastAutoResolvePendingCount = pendingChoices.Count;
        _lastAutoResolveScoresSet = session.ScoresSet;
    }

    private void SkipChoice(PendingChoice choice)
    {
        SessionService.Session!.SkipSlot(choice.Slot);
    }

    private ChoiceRecord? FindChoiceRecord(string internalId)
        => SessionService.Session?.ChoiceHistory
            .LastOrDefault(record => string.Equals(record.Element.InternalId, internalId, StringComparison.OrdinalIgnoreCase));

    private void BeginReselect(ChoiceRecord record)
    {
        var session = SessionService.Session;
        if (session is null)
            return;

        session.RemoveChoice(record);

        var replacement = SessionService.FindReplacementChoice(record);
        if (replacement is not null)
        {
            OpenSelectionModal(replacement);
        }
        else
        {
            CloseModal();
        }
    }

    private static bool IsSkippableType(string elementType) =>
        elementType.Equals("Background", StringComparison.OrdinalIgnoreCase)
        || elementType.Equals("Background Choice", StringComparison.OrdinalIgnoreCase)
        || elementType.Equals("Theme", StringComparison.OrdinalIgnoreCase)
        || elementType.Equals("Campaign Setting", StringComparison.OrdinalIgnoreCase)
        || elementType.Equals("Companion", StringComparison.OrdinalIgnoreCase);

    private static bool IsSkippableChoice(PendingChoice choice) =>
        choice.Slot.Optional
        || IsSkippableType(choice.Slot.ElementType);

    private static IEnumerable<PendingChoice> OrderPendingChoices(IReadOnlyList<PendingChoice> choices)
        => choices
            .Select((choice, index) => new { choice, index })
            // Present in wizard-step order (Race, Class, …, Feats, Powers) so a
            // kit/theme (Class step) and feats come BEFORE powers — taking a kit
            // can open new disciplines that expand the power options. Within a
            // step, required choices precede skippable/optional ones.
            .OrderBy(item => (int)item.choice.Step)
            .ThenBy(item => IsSkippableChoice(item.choice) ? 1 : 0)
            .ThenBy(item => item.index)
            .Select(item => item.choice);

    // --- Equipment browser methods ---

    private void OpenEquipmentBrowser(string slot)
    {
        _activeEquipSlot = slot;
        _equipmentCandidates = SessionService.GetAvailableEquipment(slot);
        _equipSearchText = "";
        _selectedEquipItem = null;
        _selectedEquipDetail = null;
        _showEquipmentModal = true;
    }

    private void CloseEquipmentModal()
    {
        _showEquipmentModal = false;
        _activeEquipSlot = null;
        _equipmentCandidates = null;
        _selectedEquipItem = null;
        _selectedEquipDetail = null;
    }

    private void SelectEquipCandidate(RulesElement item)
    {
        _selectedEquipItem = item;
        _selectedEquipDetail = SessionService.GetElementDetails(item.InternalId) ?? item;
    }

    private void ConfirmEquipment()
    {
        if (_selectedEquipItem is not null && _activeEquipSlot is not null)
        {
            var session = SessionService.Session!;

            // Two-handed weapon rules: a 2H weapon occupies both hand slots
            // conceptually. The .dnd4e file format stores it as a single loot
            // in Main Hand (no off-hand entry — confirmed against the OCB
            // community corpus), so we only mutate the appropriate slot here.
            if (IsTwoHandedWeapon(_selectedEquipItem))
            {
                // 2H always goes into Main Hand and clears Off-Hand.
                session.UnequipItem("Off-Hand");
                session.EquipItem("Main Hand", _selectedEquipItem);
            }
            else if (string.Equals(_activeEquipSlot, "Off-Hand", StringComparison.OrdinalIgnoreCase)
                     && session.GetEquippedItem("Main Hand") is { } current
                     && IsTwoHandedWeapon(current))
            {
                // Equipping something into Off-Hand while a 2H weapon is in
                // Main Hand frees the wielding hand.
                session.UnequipItem("Main Hand");
                session.EquipItem(_activeEquipSlot, _selectedEquipItem);
            }
            else
            {
                session.EquipItem(_activeEquipSlot, _selectedEquipItem);
            }

            CloseEquipmentModal();
        }
    }

    private void UnequipSlot(string slot)
    {
        var session = SessionService.Session!;

        // If unequipping Off-Hand while a 2H weapon is in Main Hand, the
        // user clicked the visual "two-handed occupied" placeholder — clear
        // the actual storage slot (Main Hand) instead.
        if (string.Equals(slot, "Off-Hand", StringComparison.OrdinalIgnoreCase)
            && session.GetEquippedItem("Off-Hand") is null
            && session.GetEquippedItem("Main Hand") is { } current
            && IsTwoHandedWeapon(current))
        {
            session.UnequipItem("Main Hand");
            return;
        }

        session.UnequipItem(slot);
    }

