    /// to lock in a base (e.g. when invoked from the slot picker's ✨ icon);
    /// pass <paramref name="targetSlot"/> to equip the resulting composite
    /// into that slot on confirm. Both null → free-form build, adds to inventory.
    /// </summary>
    private void OpenMagicItemBuilder(RulesElement? preselectedBase, string? targetSlot)
