@page "/"
@using CharM.Engine.Creation
@using CharM.Engine.CharacterModel
@using CharM.Engine.Economy
@using CharM.Engine.Rules
@using CharM.Web.Services
@inject CharacterSessionService SessionService
@inject CharacterRestoreState RestoreState
@implements IDisposable

<PageTitle>CharM</PageTitle>

@if (!SessionService.HasSession && RestoreState.Phase == RestorePhase.Idle)
{
    <!-- New Character Setup -->
    <div class="flex items-center justify-center min-h-[60vh]">
        <div class="bg-surface-container-lowest p-8 rounded-lg ghost-border max-w-md w-full">
            <h1 class="font-headline text-2xl font-bold text-on-surface mb-6">New Character</h1>
            <div class="space-y-4">
                <div>
                    <label class="block text-xs font-label font-semibold uppercase tracking-wider text-on-surface-variant mb-1">Character Name</label>
                    <input type="text" @bind="_characterName" class="w-full px-3 py-2 bg-surface-container-low border-b border-outline rounded text-on-surface font-body focus:border-primary focus:outline-none" placeholder="Enter character name..." />
                </div>
                <div>
                    <label class="block text-xs font-label font-semibold uppercase tracking-wider text-on-surface-variant mb-1">Level</label>
                    <input type="number" @bind="_level" min="1" max="30" class="w-full px-3 py-2 bg-surface-container-low border-b border-outline rounded text-on-surface font-body focus:border-primary focus:outline-none" />
                </div>
                <button @onclick="StartNewCharacter" class="w-full py-2.5 bg-primary text-on-primary font-label font-semibold rounded hover:bg-primary-dim transition-colors scale-98-active">
                    Create Character
                </button>
            </div>
        </div>
    </div>
}
else if (!SessionService.HasSession)
{
    <!-- Restore is pending or in progress — leave the page blank; the
         RestoreOverlay spinner (mounted in MainLayout) covers the screen
         until the saved character lands or we confirm none exists. -->
}
else
{
    var session = SessionService.Session!;
    var pendingChoices = session.GetAllPendingChoices();
    var snapshot = session.GetPartialSnapshot();

    var displayPendingChoices = OrderPendingChoices(pendingChoices).ToList();

    <!-- Compact Header -->
    <header class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8">
        <div>
            <span class="font-label text-[10px] uppercase tracking-[0.2em] text-outline mb-1 block">
                @if (_editingLevel)
                {
                    <input type="number" min="1" max="30" value="@session.Level"
                           @onchange="e => CommitLevel(e.Value?.ToString())"
                           @onblur="() => _editingLevel = false"
                           class="inline-block w-14 px-1 bg-surface-container-low border-b border-primary text-on-surface text-xs"
                           autofocus />
                }
                else
                {
                    <button @onclick="() => _editingLevel = true"
                            class="hover:text-on-surface transition-colors"
                            title="Edit level">Level @session.Level <span class="material-symbols-outlined text-[10px] align-middle">edit</span></button>
                }
                @(session.GetSelectedElement("Race")?.Name ?? "")
                @(session.GetSelectedElement("Class")?.Name ?? "")
            </span>
            @if (_editingName)
            {
                <input type="text" value="@session.Name"
                       @onchange="e => CommitName(e.Value?.ToString())"
                       @onblur="() => _editingName = false"
                       class="font-headline text-5xl font-bold text-on-surface tracking-tight bg-transparent border-b border-primary focus:outline-none w-full"
                       autofocus />
            }
            else
            {
                <h1 class="font-headline text-5xl font-bold text-on-surface tracking-tight cursor-pointer hover:opacity-80"
                    @onclick="() => _editingName = true"
                    title="Click to edit">@session.Name</h1>
            }
        </div>
        <div class="flex flex-col items-end">
            <div class="flex items-center gap-2 mb-1">
                <span class="font-label text-[10px] uppercase tracking-widest text-outline">Experience</span>
                @if (_editingXp)
                {
                    <input type="number" min="0" value="@CurrentXp"
                           @onchange="e => CommitXp(e.Value?.ToString())"
                           @onblur="() => _editingXp = false"
                           class="w-24 px-1 bg-surface-container-low border-b border-primary text-sm font-bold text-right"
                           autofocus />
                }
                else
                {
                    <button @onclick="() => _editingXp = true"
                            class="text-sm font-bold hover:text-primary transition-colors"
                            title="Click to edit XP">@CurrentXp / @XpForNextLevel(session.Level)</button>
                }
            </div>
            <div class="w-48 bg-surface-container-highest h-1.5">
                <div class="bg-primary h-full" style="width: @(XpProgressPercent(session))%;"></div>
            </div>
        </div>
    </header>

    <!-- Pending Choices Banner -->
    @if (pendingChoices.Count > 0)
    {
        <section class="bg-tertiary-container/50 p-4 rounded ghost-border mb-6">
            <h2 class="font-label text-[10px] font-bold uppercase tracking-[0.2em] text-on-tertiary-container mb-2">
                <span class="material-symbols-outlined text-sm align-middle mr-1">pending_actions</span>
                Choices Needed (@pendingChoices.Count)
            </h2>
            <div class="flex flex-wrap gap-2">
                @foreach (var choice in displayPendingChoices.Take(12))
                {
                    bool isSkippable = IsSkippableChoice(choice);
                    <div class="flex items-center gap-0.5">
                        <button @onclick="() => OpenSelectionModal(choice)"
                                class="flex items-center gap-1.5 px-3 py-1.5 bg-surface-container-lowest rounded-l ghost-border hover:bg-surface-container-low transition-colors text-left scale-98-active text-sm">
                            <span class="font-label font-semibold text-on-surface">@choice.Description</span>
                            @if (choice.Slot.Number > 1)
                            {
                                <span class="text-xs text-on-surface-variant">(×@choice.Slot.Remaining)</span>
                            }
                            <span class="material-symbols-outlined text-primary text-lg">arrow_forward</span>
                        </button>
                        @if (isSkippable)
                        {
                            <button @onclick="() => SkipChoice(choice)"
                                    class="px-2 py-1.5 bg-surface-container-lowest rounded-r ghost-border hover:bg-surface-container-low transition-colors text-xs text-outline"
                                    title="Skip this choice">
                                <span class="material-symbols-outlined text-sm">close</span>
                            </button>
                        }
                    </div>
                }
                @if (displayPendingChoices.Count > 12)
                {
                    <span class="text-xs text-on-surface-variant self-center">+@(displayPendingChoices.Count - 12) more...</span>
                }
            </div>
        </section>
    }

    <!-- Main 3-Column Grid -->
    <div class="grid grid-cols-1 md:grid-cols-4 lg:grid-cols-12 gap-6">

        <!-- Column 1: Ability Scores & Skills -->
        <div class="md:col-span-2 lg:col-span-3 space-y-6">
            @if (!session.ScoresSet)
            {
                <div class="bg-surface-container-lowest ghost-border p-4">
                    <h2 class="font-label text-[10px] font-bold uppercase tracking-[0.2em] text-outline mb-3">Ability Scores</h2>
                    <AbilityScoreEntry OnScoresSet="OnAbilityScoresSet" />
                </div>
            }
            else
            {
                <div class="space-y-2">
                    <div class="flex items-center justify-between mb-1">
                        <h2 class="font-label text-[10px] font-bold uppercase tracking-[0.2em] text-outline">Abilities &amp; Skills</h2>
                        <button @onclick="() => _editingAbilityScores = true"
                                class="text-[10px] text-on-surface-variant hover:text-primary flex items-center gap-1"
                                title="Edit ability scores">
                            <span class="material-symbols-outlined text-xs">edit</span>Edit
                        </button>
                    </div>
                    @if (_editingAbilityScores)
                    {
                        <div class="bg-surface-container-lowest ghost-border p-3">
                            <AbilityScoreEntry OnScoresSet="OnAbilityScoresEdited" />
                            <button @onclick="() => _editingAbilityScores = false"
                                    class="mt-2 w-full py-1 text-xs font-label text-on-surface-variant hover:text-on-surface">
                                Cancel
                            </button>
                        </div>
                    }
                    @foreach (var (abilityName, abilityKey) in _abilityDefs)
                    {
                        int score = snapshot?.GetStat(abilityName) ?? session.AbilityScores![abilityKey];
                        int mod = (score - 10) / 2;
                        string modStr = mod >= 0 ? $"+{mod}" : $"{mod}";
                        bool isPrimary = mod >= 3;
                        var linkedSkills = _abilityToSkills[abilityName];

                        <div class="bg-surface-container-lowest ghost-border p-2 flex items-center gap-3">
                            <div class="flex items-center gap-2 shrink-0">
                                <div class="@(isPrimary ? "bg-primary text-on-primary" : "bg-surface-container-highest text-on-surface") w-9 h-10 flex items-center justify-center font-bold text-lg ability-shield">
                                    <CalculationPopover Stats="snapshot?.Builder.Stats" StatName="@abilityName" TriggerClass="text-inherit">
                                        @modStr
                                    </CalculationPopover>
                                </div>
                                <div class="text-center">
                                    <div class="font-label text-[9px] uppercase tracking-tighter leading-none mb-0.5">@abilityName[..3].ToUpper()</div>
                                    <div class="text-[10px] font-bold border border-outline-variant/30 px-1 inline-block">
                                        <CalculationPopover Stats="snapshot?.Builder.Stats" StatName="@abilityName" TriggerClass="text-inherit">
                                            @score
                                        </CalculationPopover>
                                    </div>
                                </div>
                            </div>
                            <div class="flex-grow space-y-0.5">
                                @foreach (var skill in linkedSkills)
                                {
                                    int skillVal = snapshot?.GetStat(skill) ?? mod;
                                    bool trained = snapshot is not null && snapshot.GetStat(skill + " Trained") > 0;
                                    string skillStr = skillVal >= 0 ? $"+{skillVal}" : $"{skillVal}";

                                    <div class="flex justify-between items-center text-[10px] px-1.5 @(trained ? "py-0.5 bg-surface-container-low font-bold" : "text-outline")">
                                        <span>@skill</span>
                                        <span>
                                            <CalculationPopover Stats="snapshot?.Builder.Stats" StatName="@skill" TriggerClass="text-inherit">
                                                @skillStr
                                            </CalculationPopover>
                                        </span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- Money / Economics -->
            @{
                var carried = session.CarriedMoney;
                var stored = session.StoredMoney;
                var carriedNegative = carried.IsNegative;
            }
            <section class="bg-surface-container-lowest ghost-border overflow-hidden">
                <div class="bg-stone-200/50 px-4 py-2 flex justify-between items-center border-b border-outline-variant/20">
                    <h2 class="font-label text-[10px] font-bold uppercase tracking-widest text-on-surface/70">Money</h2>
                    <button @onclick="ApplyAutoGold"
                            class="text-[10px] font-label uppercase tracking-wider px-2 py-0.5 rounded bg-primary text-on-primary hover:bg-primary/90 transition-colors no-print"
                            title="Set the by-the-book level-appropriate starting gold for this character">
                        Level Gold
                    </button>
                </div>
                <div class="p-3 space-y-1">
                    <div class="flex items-center justify-between text-[11px]">
                        <span class="text-outline uppercase tracking-wider">Carried</span>
                        <span class="font-bold tabular-nums @(carriedNegative ? "text-error" : "text-on-surface")">@carried.ToString()</span>
                    </div>
                    <div class="flex items-center justify-between text-[11px]">
                        <span class="text-outline uppercase tracking-wider">Stored</span>
                        <span class="font-bold tabular-nums text-on-surface">@stored.ToString()</span>
                    </div>
                    @if (carriedNegative)
                    {
                        <div class="text-[10px] text-error italic pt-1 flex items-center gap-1">
                            <span class="material-symbols-outlined text-[12px]">warning</span>
                            Carried money is negative — you've overspent.
                        </div>
                    }
                    @if (StartingGoldTable.IsPlaceholder(session.Level))
                    {
                        <div class="text-[10px] text-outline italic pt-1 no-print">
                            Note: level-appropriate gold for level @session.Level is a placeholder pending exact rulebook values.
                        </div>
                    }
                </div>
            </section>

            <!-- Inventory (non-slot gear: gear, consumables, mundane items) -->
            <section class="bg-surface-container-lowest ghost-border overflow-hidden">
                <div class="bg-stone-200/50 px-4 py-2 flex justify-between items-center border-b border-outline-variant/20">
                    <h2 class="font-label text-[10px] font-bold uppercase tracking-widest text-on-surface/70">Inventory</h2>
                    <button @onclick="OpenInventoryBrowser"
                            class="text-[10px] font-label uppercase tracking-wider px-2 py-0.5 rounded bg-primary text-on-primary hover:bg-primary/90 transition-colors no-print"
                            title="Add an item">
                        + Add
                    </button>
                </div>
                <div class="p-3 space-y-1">
                    @{
                        var equippedIds = new HashSet<string>(
                            _equipSlots.Select(s => session.GetEquippedItem(s)?.InternalId)
                                       .Where(id => id is not null)!,
                            StringComparer.OrdinalIgnoreCase);
                        var inventory = session.GetInventory()
                            .Where(inv => !RitualPracticeAlchemyClassifier.IsRitualPracticeAlchemyElement(inv.Item.Base))
                            .Where(inv => inv.Item.Base.InternalId is null || !equippedIds.Contains(inv.Item.Base.InternalId))
                            .ToList();
                    }
                    @if (inventory.Count == 0)
                    {
                        <div class="text-[10px] text-outline italic py-2 text-center">No items yet.</div>
                    }
                    else
                    {
                        @foreach (var inv in inventory)
                        {
                            var invId = inv.Item.Base.InternalId;
                            <div class="flex items-center justify-between gap-2 text-[10px] border-b border-outline-variant/10 pb-1 group cursor-pointer hover:bg-surface-container-low/50 transition-colors -mx-1 px-1 rounded"
                                 @onclick="() => OpenDetailModal(invId)">
                                <div class="flex items-center gap-2 min-w-0">
                                    <button @onclick="() => DecrementInventory(invId, inv.Quantity)"
                                            @onclick:stopPropagation="true"
                                            class="text-outline hover:text-on-surface w-4 h-4 leading-none rounded hover:bg-surface-container no-print"
                                            title="Decrease quantity">−</button>
                                    <span class="font-bold text-on-surface w-5 text-center">@inv.Quantity</span>
                                    <button @onclick="() => IncrementInventory(invId)"
                                            @onclick:stopPropagation="true"
                                            class="text-outline hover:text-on-surface w-4 h-4 leading-none rounded hover:bg-surface-container no-print"
                                            title="Increase quantity">+</button>
                                    <span class="truncate text-on-surface font-semibold">@(inv.Item.CompositeName ?? inv.Item.Base.Name)</span>
                                </div>
                                <button @onclick="() => RemoveInventoryEntry(invId)"
                                        @onclick:stopPropagation="true"
                                        class="opacity-0 group-hover:opacity-100 transition-opacity text-error shrink-0 no-print"
                                        title="Remove">
                                    <span class="material-symbols-outlined text-[12px]">close</span>
                                </button>
                            </div>
                        }
                    }
                </div>
            </section>

            @{
                var ritualPracticeAlchemyRows = session.GetRitualPracticeAlchemyEntries();
            }
            <section class="bg-surface-container-lowest ghost-border overflow-hidden">
                <div class="bg-stone-200/50 px-4 py-2 flex justify-between items-center border-b border-outline-variant/20">
                    <h2 class="font-label text-[10px] font-bold uppercase tracking-widest text-on-surface/70">Rituals, Alchemy &amp; Practices</h2>
                    <button @onclick="OpenRitualPracticeAlchemyBrowser"
                            class="text-[10px] font-label uppercase tracking-wider px-2 py-0.5 rounded bg-primary text-on-primary hover:bg-primary/90 transition-colors no-print"
                            title="Add a ritual, formula, scroll, or alchemical item">
                        + Add
                    </button>
                </div>
                <div class="p-3 space-y-3">
                    @if (ritualPracticeAlchemyRows.Count == 0)
                    {
                        <div class="text-[10px] text-outline italic py-2 text-center">No rituals, formulae, or practices yet.</div>
                    }
                    else
                    {
                        @foreach (var group in ritualPracticeAlchemyRows.GroupBy(row => row.Kind).OrderBy(group => RitualPracticeAlchemyClassifier.KindSortKey(group.Key)))
                        {
                            <div>
                                <div class="text-[9px] font-label font-bold uppercase tracking-widest text-outline mb-1">
                                    @FormatRitualPracticeAlchemyKind(group.Key)
                                </div>
                                <div class="space-y-1">
                                    @foreach (var row in group.OrderBy(r => LevelSortKey(r.Element)).ThenBy(r => r.Element.Name, StringComparer.OrdinalIgnoreCase))
                                    {
                                        var elementId = row.Element.InternalId;
                                        <div class="flex items-center justify-between gap-2 text-[10px] border-b border-outline-variant/10 pb-1 group cursor-pointer hover:bg-surface-container-low/50 transition-colors -mx-1 px-1 rounded"
                                             @onclick="() => OpenDetailModal(elementId)">
                                            <div class="min-w-0">
                                                <span class="truncate text-on-surface font-semibold">@row.Element.Name</span>
                                                <span class="text-outline ml-1">@RitualPracticeAlchemyMeta(row)</span>
                                            </div>
                                            @if (row.IsInventoryItem && elementId is not null)
                                            {
                                                <div class="flex items-center gap-1 no-print">
                                                    <button @onclick="() => DecrementInventory(elementId, row.Quantity)"
                                                            @onclick:stopPropagation="true"
                                                            class="text-outline hover:text-on-surface w-4 h-4 leading-none rounded hover:bg-surface-container"
                                                            title="Decrease quantity">−</button>
                                                    <span class="font-bold text-on-surface w-5 text-center">@row.Quantity</span>
                                                    <button @onclick="() => IncrementInventory(elementId)"
                                                            @onclick:stopPropagation="true"
                                                            class="text-outline hover:text-on-surface w-4 h-4 leading-none rounded hover:bg-surface-container"
                                                            title="Increase quantity">+</button>
                                                    <button @onclick="() => RemoveInventoryEntry(elementId)"
                                                            @onclick:stopPropagation="true"
                                                            class="opacity-0 group-hover:opacity-100 transition-opacity text-error shrink-0"
                                                            title="Remove">
                                                        <span class="material-symbols-outlined text-[12px]">close</span>
                                                    </button>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="text-[9px] text-outline uppercase tracking-wide">Granted</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </section>
        </div>

        <!-- Column 2: Vitals, Defenses & Equipment -->
        <div class="md:col-span-2 lg:col-span-5 space-y-6">
            <section class="bg-surface-container-lowest ghost-border overflow-hidden">
                <div class="bg-tertiary-container px-4 py-2 border-b border-outline-variant/20">
                    <h2 class="font-label text-[10px] font-bold uppercase tracking-widest text-on-tertiary-container">Vitality &amp; Defense</h2>
                </div>
                <div class="p-4 grid grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-6">
                    <ResourceTrackerPanel Stats="snapshot?.Builder.Stats">
                        <ActionPointContent>
                            <div class="flex items-center gap-2">
                                <button @onclick="DecrementActionPoints"
                                        class="w-5 h-5 flex items-center justify-center text-outline hover:text-on-surface bg-surface-container-low rounded text-xs no-print"
                                        title="Decrease">−</button>
                                <span class="text-xl font-bold min-w-[1.5rem] text-center">@_actionPoints</span>
                                <button @onclick="IncrementActionPoints"
                                        class="w-5 h-5 flex items-center justify-center text-outline hover:text-on-surface bg-surface-container-low rounded text-xs no-print"
                                        title="Increase">+</button>
                            </div>
                        </ActionPointContent>
                    </ResourceTrackerPanel>
                    <!-- Defense & Tactical Grid -->
                    <div class="col-span-2 lg:col-span-3 pt-4 border-t border-outline-variant/20">
                        <div class="flex gap-4">
                            <div class="grid grid-cols-2 gap-3 shrink-0">
                                @foreach (var (statName, label, cssClass) in new[] { ("AC", "AC", "defense-ac"), ("Fortitude Defense", "FORT", "defense-fort"), ("Reflex Defense", "REFL", "defense-refl"), ("Will Defense", "WILL", "defense-will") })
                                {
                                    int val = snapshot?.GetStat(statName) ?? 10;
                                    <div class="relative w-16 h-16 flex flex-col items-center justify-center">
                                        <div class="absolute inset-0 @cssClass"></div>
                                        <span class="relative z-10 text-lg font-bold leading-none text-white mt-[-2px]">
                                            <CalculationPopover Stats="snapshot?.Builder.Stats" StatName="@statName" TriggerClass="text-white hover:text-white">
                                                @val
                                            </CalculationPopover>
                                        </span>
                                        <span class="relative z-10 text-[8px] font-label uppercase leading-none mt-1 text-white/70">@label</span>
                                    </div>
                                }
                            </div>
                            <div class="flex-grow space-y-2 py-0.5">
                                @foreach (var (statName, label) in new[] { ("Initiative", "Initiative"), ("Speed", "Speed"), ("Passive Insight", "Passive Insight"), ("Passive Perception", "Passive Perception") })
                                {
                                    int val = snapshot?.GetStat(statName) ?? 0;
                                    <div class="flex justify-between items-center text-[10px] px-3 py-1.5 bg-surface-container-low border border-outline-variant/10">
                                        <span class="font-label uppercase tracking-widest text-outline">@label</span>
                                        <span class="font-bold">
                                            <CalculationPopover Stats="snapshot?.Builder.Stats" StatName="@statName" TriggerClass="text-inherit">
                                                @FormatTacticalStat(statName, val)
                                            </CalculationPopover>
                                        </span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Equipped Items (with slot-based layout and detailed formatting) -->
            <section class="bg-surface-container-lowest ghost-border overflow-hidden">
                <div class="bg-stone-200/50 px-4 py-2 flex justify-between items-center border-b border-outline-variant/20">
                    <h2 class="font-label text-[10px] font-bold uppercase tracking-widest text-on-surface/70">Equipped Items</h2>
                    <button @onclick="() => OpenMagicItemBuilder(null, null)"
                            class="text-[10px] font-label uppercase tracking-wider px-2 py-0.5 rounded bg-primary text-on-primary hover:bg-primary/90 transition-colors no-print"
                            title="Build or add a magic item (enchanted weapon/armor, wondrous item, etc.)">
                        + Magic
                    </button>
                </div>
                <div class="p-3 space-y-2">
                    @foreach (var slot in _equipSlots)
                    {
                        var equipped = session.GetEquippedItem(slot);

                        // Visual two-handed: if this is the Off-Hand row and
                        // a 2H weapon is in Main Hand, the off-hand is
                        // "occupied" by the wielding hand. Storage stays
                        // Main-Hand-only (matches OCB file format).
                        var twoHandedFromMain = equipped is null
                            && string.Equals(slot, "Off-Hand", StringComparison.OrdinalIgnoreCase)
                            && session.GetEquippedItem("Main Hand") is { } mh
                            && IsTwoHandedWeapon(mh)
                            ? mh
                            : null;

                        @if (twoHandedFromMain is not null)
                        {
                            <div class="flex justify-between items-center text-[10px] border-b border-outline-variant/10 pb-1 cursor-pointer hover:bg-surface-container-low/50 transition-colors -mx-1 px-1 rounded group"
                                 @onclick="() => UnequipSlot(slot)"
                                 title="Two-handed — unequip @twoHandedFromMain.Name">
                                <span class="font-bold text-outline uppercase tracking-tighter">@slot</span>
                                <span class="text-outline italic">
                                    <span class="material-symbols-outlined text-[11px] align-middle">link</span>
                                    Two-Handed (@twoHandedFromMain.Name)
                                </span>
                            </div>
                        }
                        else if (equipped is not null)
                        {
                            var detail = SessionService.GetElementDetails(equipped.InternalId);
                            <div class="border-b border-outline-variant/10 pb-2 group cursor-pointer hover:bg-surface-container-low/50 transition-colors -mx-1 px-1 rounded"
                                 @onclick="() => OpenEquipmentBrowser(slot)">
                                <div class="flex items-start justify-between gap-2">
                                    <div class="min-w-0">
                                        <span class="text-sm font-bold">@equipped.Name</span>
                                        <span class="text-[10px] text-outline ml-1">(@slot)</span>
                                    </div>
                                    <button @onclick="() => UnequipSlot(slot)" @onclick:stopPropagation="true"
                                            class="opacity-0 group-hover:opacity-100 transition-opacity text-error shrink-0 no-print mt-0.5"
                                            title="Unequip">
                                        <span class="material-symbols-outlined text-[12px]">close</span>
                                    </button>
                                </div>
                                @if (detail?.Fields.TryGetValue("Short Description", out var desc) == true && !string.IsNullOrEmpty(desc))
                                {
                                    <p class="text-[11px] text-outline leading-tight mt-0.5">@desc</p>
                                }
                                @{
                                    var itemFields = GetEquipmentSummary(detail ?? equipped);
                                }
                                @if (itemFields.Count > 0)
                                {
                                    <div class="flex flex-wrap gap-x-3 gap-y-0.5 mt-1">
                                        @foreach (var (fieldName, fieldValue) in itemFields)
                                        {
                                            <span class="text-[9px]">
                                                <span class="text-outline uppercase">@fieldName:</span>
                                                <span class="font-bold">@fieldValue</span>
                                            </span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="flex justify-between items-center text-[10px] border-b border-outline-variant/10 pb-1 cursor-pointer hover:bg-surface-container-low/50 transition-colors -mx-1 px-1 rounded"
                                 @onclick="() => OpenEquipmentBrowser(slot)">
                                <span class="font-bold text-outline uppercase tracking-tighter">@slot</span>
                                <span class="text-outline/50 italic hover:text-primary/70">None</span>
                            </div>
                        }
                    }
                </div>
            </section>
        </div>

        <!-- Column 3: Features & Overview -->
        <div class="md:col-span-4 lg:col-span-4 space-y-6">
            <!-- Character Overview -->
            <div class="bg-surface-container-lowest ghost-border overflow-hidden">
                <div class="bg-stone-200/50 px-4 py-2 border-b border-outline-variant/20">
                    <h2 class="font-label text-[10px] font-bold uppercase tracking-widest text-outline">Character Overview</h2>
                </div>
                <div class="p-4 space-y-4">
                    <div class="flex gap-4">
                        <div class="flex-1">
                            <h3 class="font-label text-[9px] font-bold uppercase text-outline mb-1">Alignment</h3>
                            @if (_editingAlignment)
                            {
                                <select @onchange="e => CommitAlignment(e.Value?.ToString())"
                                        @onblur="() => _editingAlignment = false"
                                        class="text-xs font-bold px-2 py-0.5 bg-surface-container-low border border-outline-variant/20 focus:border-primary focus:outline-none"
                                        autofocus>
                                    @foreach (var a in _alignments)
                                    {
                                        <option value="@a" selected="@(a == session.Details.GetValueOrDefault("Alignment", "Unaligned"))">@a</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <button @onclick="() => _editingAlignment = true"
                                        class="text-xs font-bold px-2 py-0.5 bg-surface-container-low border border-outline-variant/20 hover:border-primary transition-colors cursor-pointer"
                                        title="Click to change alignment">
                                    @(session.Details.GetValueOrDefault("Alignment", "Unaligned"))
                                </button>
                            }
                        </div>
                        <div class="flex-1">
                            <h3 class="font-label text-[9px] font-bold uppercase text-outline mb-1">Languages</h3>
                            <div class="space-y-1">
                                @{
                                    var languages = session.GetAllElementsOfType("Language");
                                    var langsBySource = languages
                                        .GroupBy(l => l.Source ?? "Other")
                                        .OrderBy(g => g.Key, StringComparer.OrdinalIgnoreCase);
                                }
                                @if (languages.Count > 0)
                                {
                                    @foreach (var group in langsBySource)
                                    {
                                        <div>
                                            <span class="text-[8px] font-label uppercase tracking-wider text-outline/60">@group.Key</span>
                                            <div class="flex flex-wrap gap-1 mt-0.5">
                                                @foreach (var lang in group)
                                                {
                                                    var choiceRecord = FindChoiceRecord(lang.InternalId);
                                                    <span class="group inline-flex items-center gap-1 text-[10px] bg-white px-1.5 py-0.5 border border-outline-variant/20">
                                                        <span>@lang.Name</span>
                                                        @if (choiceRecord is not null)
                                                        {
                                                            <button @onclick="() => BeginReselect(choiceRecord)"
                                                                    class="opacity-0 group-hover:opacity-100 transition-opacity text-error no-print"
                                                                    title="Reselect this language">
                                                                <span class="material-symbols-outlined text-[12px]">edit</span>
                                                            </button>
                                                        }
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <span class="text-[10px] text-outline italic">None selected</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Class Features -->
            @{
                var classFeatures = session.GetAllElementsOfType("Class Feature");
                var groupedFeatures = GroupClassFeatures(classFeatures);
            }
            @if (classFeatures.Count > 0)
            {
                <section class="bg-surface-container-lowest ghost-border overflow-hidden">
                    <div class="bg-tertiary-container px-4 py-2 flex justify-between items-center border-b border-outline-variant/20">
                        <h2 class="font-label text-[10px] font-bold uppercase tracking-widest text-on-tertiary-container">Class Features</h2>
                    </div>
                    <div class="p-3 space-y-1.5">
                        @foreach (var group in groupedFeatures)
                        {
                            @if (group.Children.Count > 0)
                            {
                                // Intermediate parent with same-type children: render as header
                                var headerId = group.Parent.InternalId;
                                <div class="mt-1.5 first:mt-0">
                                    <div class="flex items-center gap-1.5 mb-0.5 cursor-pointer" @onclick="() => OpenDetailModal(headerId)">
                                        <span class="font-label text-[9px] font-bold uppercase tracking-widest text-outline">@group.Parent.Name</span>
                                    </div>
                                    <div class="border-l-2 border-outline-variant/30 pl-2 space-y-1">
                                        @foreach (var child in group.Children)
                                        {
                                            var childDetail = SessionService.GetElementDetails(child.InternalId);
                                            var childRecord = FindChoiceRecord(child.InternalId);
                                            var childId = child.InternalId;
                                            <div class="group border-b border-outline-variant/10 pb-1.5 cursor-pointer hover:bg-surface-container-low/40 -mx-2 px-2 rounded transition-colors"
                                                 @onclick="() => OpenDetailModal(childId)">
                                                <div class="flex items-start justify-between gap-2">
                                                    <h3 class="text-sm font-bold">
                                                        @child.Name
                                                        @if (IsHouseruledElement(child.InternalId))
                                                        {
                                                            <HouseruleBadge />
                                                        }
                                                    </h3>
                                                    @if (childRecord is not null)
                                                    {
                                                        <button @onclick="() => BeginReselect(childRecord)"
                                                                @onclick:stopPropagation="true"
                                                                class="opacity-0 group-hover:opacity-100 transition-opacity p-1 rounded hover:bg-error-container/20 text-error no-print"
                                                                title="Reselect this choice">
                                                            <span class="material-symbols-outlined text-base">edit</span>
                                                        </button>
                                                    }
                                                </div>
                                                @if (childDetail?.Fields.TryGetValue("Short Description", out var childDesc) == true && !string.IsNullOrEmpty(childDesc))
                                                {
                                                    <p class="text-[11px] text-outline leading-tight">@childDesc</p>
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                            else
                            {
                                // Regular feature or grant-only intermediate
                                var feature = group.Parent;
                                var detail = SessionService.GetElementDetails(feature.InternalId);
                                var choiceRecord = FindChoiceRecord(feature.InternalId);
                                var featureId = feature.InternalId;
                                <div class="group border-b border-outline-variant/10 pb-1.5 cursor-pointer hover:bg-surface-container-low/40 -mx-2 px-2 rounded transition-colors"
                                     @onclick="() => OpenDetailModal(featureId)">
                                    <div class="flex items-start justify-between gap-2">
                                        <h3 class="text-sm font-bold">
                                            @feature.Name
                                            @if (IsHouseruledElement(feature.InternalId))
                                            {
                                                <HouseruleBadge />
                                            }
                                        </h3>
                                        @if (choiceRecord is not null)
                                        {
                                            <button @onclick="() => BeginReselect(choiceRecord)"
                                                    @onclick:stopPropagation="true"
                                                    class="opacity-0 group-hover:opacity-100 transition-opacity p-1 rounded hover:bg-error-container/20 text-error no-print"
                                                    title="Reselect this choice">
                                                <span class="material-symbols-outlined text-base">edit</span>
                                            </button>
                                        }
                                    </div>
                                    @if (group.GrantLinks.Count > 0)
                                    {
                                        @foreach (var link in group.GrantLinks)
                                        {
                                            var linkId = link.InternalId;
                                            <p class="text-[11px] text-outline leading-tight hover:text-primary cursor-pointer"
                                               @onclick="() => OpenDetailModal(linkId)" @onclick:stopPropagation="true"
                                               title="View details">@link.Label</p>
                                        }
                                    }
                                    else if (detail?.Fields.TryGetValue("Short Description", out var desc) == true && !string.IsNullOrEmpty(desc))
                                    {
                                        <p class="text-[11px] text-outline leading-tight">@desc</p>
                                    }
                                </div>
                            }
                        }
                    </div>
                </section>
            }

            <!-- Feats & Traits -->
            @{
                var feats = session.GetSelectedElements("Feat");
                var racialTraits = session.GetAllElementsOfType("Racial Trait");
            }
            @if (feats.Count > 0 || racialTraits.Count > 0)
            {
                <div class="bg-surface-container-lowest ghost-border overflow-hidden">
                    <div class="bg-stone-200/50 px-4 py-2 flex justify-between items-center border-b border-outline-variant/20">
                        <h2 class="font-label text-[10px] font-bold uppercase tracking-widest text-on-surface/70">Feats &amp; Traits</h2>
                    </div>
                    <div class="p-3 space-y-1.5">
                        @foreach (var feat in feats.Concat(racialTraits))
                        {
                            var detail = SessionService.GetElementDetails(feat.InternalId);
                            var choiceRecord = FindChoiceRecord(feat.InternalId);
                            var featId = feat.InternalId;
                            <div class="group border-b border-outline-variant/10 pb-1.5 cursor-pointer hover:bg-surface-container-low/40 -mx-2 px-2 rounded transition-colors"
                                 @onclick="() => OpenDetailModal(featId)">
                                <div class="flex items-start justify-between gap-2">
                                    <h3 class="text-sm font-bold">
                                        @feat.Name
                                        @if (IsHouseruledElement(feat.InternalId))
                                        {
                                            <HouseruleBadge />
                                        }
                                    </h3>
                                    @if (choiceRecord is not null)
                                    {
                                        <button @onclick="() => BeginReselect(choiceRecord)"
                                                @onclick:stopPropagation="true"
                                                class="opacity-0 group-hover:opacity-100 transition-opacity p-1 rounded hover:bg-error-container/20 text-error no-print"
                                                title="Reselect this choice">
                                            <span class="material-symbols-outlined text-base">edit</span>
                                        </button>
                                    }
                                </div>
                                @if (detail?.Fields.TryGetValue("Short Description", out var desc) == true && !string.IsNullOrEmpty(desc))
                                {
                                    <p class="text-[11px] text-outline leading-tight">@desc</p>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            @if (session.IsComplete)
            {
            }
        </div>
    </div>

    @if (_showCompleteToast)
    {
        <div class="fixed top-20 left-1/2 -translate-x-1/2 z-40 flex items-center gap-2 px-6 py-3 bg-tertiary-container rounded-lg shadow-lg ghost-border no-print">
            <span class="material-symbols-outlined text-on-tertiary-container">check_circle</span>
            <span class="text-sm font-label font-semibold text-on-tertiary-container">Character Complete — ready to export or print</span>
        </div>
    }

    <!-- Selection Modal -->
    @if (_showModal && _activeChoice is not null)
    {
        <SelectionModal Choice="_activeChoice"
                        Candidates="_modalCandidates"
                        RecommendedIds="@(SessionService.Session?.GetSuggestedIdsForSlot(_activeChoice.Slot))"
                        OnSelect="OnElementSelected"
                        OnClose="CloseModal"
                        OnLoadDetails="LoadElementDetails"
                        OnResolveIds="ResolveElementIds" />
    }

    @if (_detailModalElement is not null)
    {
        <ElementDetailModal Element="_detailModalElement"
                            OnClose="CloseDetailModal"
                            OnLoadDetails="LoadElementDetails"
                            OnResolveIds="ResolveElementIds" />
    }

    @if (_showInventoryModal)
    {
        <div class="fixed inset-0 z-50 bg-inverse-surface/40 backdrop-blur-sm flex items-center justify-center p-4"
             @onclick="CloseInventoryModal">
            <div class="bg-surface-container-lowest rounded-lg shadow-lg max-w-5xl w-full max-h-[80vh] flex flex-col ghost-border"
                 @onclick:stopPropagation="true">
                <div class="px-6 py-4 border-b border-outline-variant/20">
                    <div class="flex items-center justify-between">
                        <div>
                            <h2 class="font-headline text-xl font-bold text-on-surface">Add to Inventory</h2>
                            <p class="text-xs font-label text-on-surface-variant mt-0.5">Choose an item to add to your gear list</p>
                        </div>
                        <button @onclick="CloseInventoryModal"
                                class="p-1 rounded hover:bg-surface-container-low transition-colors">
                            <span class="material-symbols-outlined text-on-surface-variant">close</span>
                        </button>
                    </div>
                    <div class="mt-3 relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-lg">search</span>
                        <input type="text" @bind="_inventorySearchText" @bind:event="oninput"
                               placeholder="Search items..."
                               class="w-full pl-9 pr-3 py-2 bg-surface-container-low border-b border-outline rounded text-sm font-body text-on-surface focus:border-primary focus:outline-none" />
                    </div>
                </div>
                <div class="flex-1 overflow-hidden flex">
                    <!-- Item list (left) -->
                    <div class="flex-1 overflow-y-auto p-2 @(_selectedInventoryDetail is not null ? "border-r border-outline-variant/20" : "")">
                        @{ var invFiltered = FilteredInventoryCandidates; }
                        @if (invFiltered.Count == 0)
                        {
                            <div class="p-6 text-center text-sm text-outline italic">No matching items found.</div>
                        }
                        else
                        {
                            <div class="flex items-center gap-2 px-3 py-1 border-b border-outline-variant/20 text-[9px] font-label font-bold uppercase tracking-widest text-outline">
                                <span class="flex-1">Item</span>
                                <span class="shrink-0 w-20 text-right">Cost</span>
                                <span class="shrink-0 w-5"></span>
                            </div>
                            var invGroups = invFiltered
                                .GroupBy(i => i.Type)
                                .OrderBy(g => g.Key, StringComparer.OrdinalIgnoreCase);
                            bool isSearching = !string.IsNullOrWhiteSpace(_inventorySearchText);
                            @foreach (var typeGroup in invGroups)
                            {
                                bool expanded = isSearching || _expandedInventoryTypes.Contains(typeGroup.Key);
                                <div class="mb-1">
                                    <button @onclick="() => ToggleInventoryType(typeGroup.Key)"
                                            class="w-full flex items-center justify-between px-3 py-1.5 bg-surface-container-low/60 hover:bg-surface-container-low transition-colors rounded text-left">
                                        <span class="font-label text-[10px] font-bold uppercase tracking-widest text-outline">@typeGroup.Key (@typeGroup.Count())</span>
                                        <span class="material-symbols-outlined text-outline text-sm">@(expanded ? "expand_less" : "expand_more")</span>
                                    </button>
                                    @if (expanded)
                                    {
                                        <ul class="divide-y divide-outline-variant/10">
                                            @foreach (var item in typeGroup.Take(200))
                                            {
                                                bool isSelected = _selectedInventoryDetail?.InternalId == item.InternalId;
                                                var costDisplay = FormatItemCost(item);
                                                <li>
                                                    <div class="flex items-center gap-2 px-3 py-1.5 @(isSelected ? "bg-surface-container-low" : "hover:bg-surface-container-low/40") transition-colors cursor-pointer"
                                                         @onclick="() => SelectInventoryItem(item)">
                                                        <div class="min-w-0 flex-1">
                                                            <div class="text-sm font-bold text-on-surface truncate">@item.Name</div>
                                                            <div class="text-[10px] text-outline uppercase tracking-wider">
                                                                @if (item.Source is not null)
                                                                {
                                                                    @item.Source
                                                                }
                                                            </div>
                                                        </div>
                                                        <div class="shrink-0 w-20 text-right text-[11px] font-label tabular-nums @(costDisplay is null ? "text-outline/40 italic" : "text-on-surface-variant")">
                                                            @(costDisplay ?? "—")
                                                        </div>
                                                        <button @onclick="() => BuyToInventory(item)" @onclick:stopPropagation="true"
                                                                class="shrink-0 p-0.5 rounded hover:bg-primary/10 transition-colors disabled:opacity-30"
                                                                disabled="@(costDisplay is null)"
                                                                title="Buy (deducts gold)">
                                                            <span class="material-symbols-outlined text-primary text-lg">paid</span>
                                                        </button>
                                                        <button @onclick="() => AddToInventory(item)" @onclick:stopPropagation="true"
                                                                class="shrink-0 p-0.5 rounded hover:bg-primary/10 transition-colors"
                                                                title="Add for free (no cost)">
                                                            <span class="material-symbols-outlined text-primary text-lg">add_circle</span>
                                                        </button>
                                                    </div>
                                                </li>
                                            }
                                        </ul>
                                        @if (typeGroup.Count() > 200)
                                        {
                                            <div class="px-3 py-1 text-[10px] text-outline italic text-center">
                                                Showing first 200 of @typeGroup.Count() — refine search to narrow.
                                            </div>
                                        }
                                    }
                                </div>
                            }
                        }
                    </div>
                    <!-- Detail panel (right) -->
                    @if (_selectedInventoryDetail is not null)
                    {
                        <div class="w-80 overflow-y-auto p-4 space-y-3">
                            <h3 class="font-headline text-lg font-bold text-on-surface">@_selectedInventoryDetail.Name</h3>
                            <div class="text-[10px] text-outline uppercase tracking-wider">@_selectedInventoryDetail.Type</div>
                            @if (_selectedInventoryDetail.Source is not null)
                            {
                                <div class="text-[10px] text-outline">@_selectedInventoryDetail.Source</div>
                            }
                            @{
                                var invDetailFields = GetEquipmentSummary(_selectedInventoryDetail);
                            }
                            @if (invDetailFields.Count > 0)
                            {
                                <div class="flex flex-wrap gap-x-3 gap-y-1 mt-1">
                                    @foreach (var (fieldName, fieldValue) in invDetailFields)
                                    {
                                        <span class="text-[10px]">
                                            <span class="text-outline uppercase">@fieldName:</span>
                                            <span class="font-bold">@fieldValue</span>
                                        </span>
                                    }
                                </div>
                            }
                            @if (_selectedInventoryDetail.Fields.TryGetValue("Short Description", out var invDesc) && !string.IsNullOrEmpty(invDesc))
                            {
                                <p class="text-xs text-on-surface leading-relaxed mt-2">@invDesc</p>
                            }
                            else if (_selectedInventoryDetail.Fields.TryGetValue("Description", out var invFullDesc) && !string.IsNullOrEmpty(invFullDesc))
                            {
                                <p class="text-xs text-on-surface leading-relaxed mt-2">@invFullDesc</p>
                            }
                            @{
                                var invDetailCost = FormatItemCost(_selectedInventoryDetail);
                            }
                            <div class="mt-3 space-y-2">
                                @if (invDetailCost is not null)
                                {
                                    <button @onclick="() => BuyToInventory(_selectedInventoryDetail)"
                                            class="w-full py-2 bg-primary text-on-primary font-label font-semibold rounded text-sm hover:bg-primary-dim transition-colors flex items-center justify-center gap-1">
                                        <span class="material-symbols-outlined text-base">paid</span>
                                        Buy (@invDetailCost)
                                    </button>
                                }
                                <button @onclick="() => AddToInventory(_selectedInventoryDetail)"
                                        class="w-full py-2 bg-surface-container-low text-on-surface font-label font-semibold rounded text-sm hover:bg-surface-container transition-colors">
                                    Add for Free
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @if (_showRitualPracticeAlchemyModal)
    {
        <div class="fixed inset-0 z-50 bg-inverse-surface/40 backdrop-blur-sm flex items-center justify-center p-4"
             @onclick="CloseRitualPracticeAlchemyModal">
            <div class="bg-surface-container-lowest rounded-lg shadow-lg max-w-3xl w-full max-h-[80vh] flex flex-col ghost-border"
                 @onclick:stopPropagation="true">
                <div class="px-6 py-4 border-b border-outline-variant/20">
                    <div class="flex items-center justify-between">
                        <div>
                            <h2 class="font-headline text-xl font-bold text-on-surface">Add Ritual, Formula, or Alchemical Item</h2>
                            <p class="text-xs font-label text-on-surface-variant mt-0.5">These are stored as non-equipped loot, matching the Character Builder ritual workflow.</p>
                        </div>
                        <button @onclick="CloseRitualPracticeAlchemyModal"
                                class="p-1 rounded hover:bg-surface-container-low transition-colors">
                            <span class="material-symbols-outlined text-on-surface-variant">close</span>
                        </button>
                    </div>
                    <div class="mt-3 grid grid-cols-1 md:grid-cols-[1fr_auto] gap-2">
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-lg">search</span>
                            <input type="text" @bind="_ritualPracticeAlchemySearchText" @bind:event="oninput"
                                   placeholder="Search rituals, formulae, scrolls, and alchemical items..."
                                   class="w-full pl-9 pr-3 py-2 bg-surface-container-low border-b border-outline rounded text-sm font-body text-on-surface focus:border-primary focus:outline-none" />
                        </div>
                        <select @bind="_ritualPracticeAlchemyKindFilter"
                                class="px-3 py-2 bg-surface-container-low border-b border-outline rounded text-xs font-label uppercase tracking-wide text-on-surface focus:border-primary focus:outline-none">
                            <option value="">All</option>
                            <option value="Ritual">Rituals</option>
                            <option value="AlchemicalFormula">Formulae</option>
                            <option value="AlchemicalItem">Alchemical Items</option>
                            <option value="RitualScroll">Scrolls</option>
                        </select>
                    </div>
                </div>
                <div class="flex-1 overflow-y-auto p-2">
                    @{ var rpaFiltered = FilteredRitualPracticeAlchemyCandidates; }
                    @if (rpaFiltered.Count == 0)
                    {
                        <div class="p-6 text-center text-sm text-outline italic">No matching entries found.</div>
                    }
                    else
                    {
                        <div class="flex items-center gap-3 px-3 py-1 border-b border-outline-variant/20 text-[9px] font-label font-bold uppercase tracking-widest text-outline">
                            <span class="flex-1">Entry</span>
                            <span class="shrink-0 w-24 text-right">Cost</span>
                            <span class="shrink-0 w-5"></span>
                        </div>
                        <ul class="divide-y divide-outline-variant/10">
                            @foreach (var item in rpaFiltered.Take(200))
                            {
                                var kind = RitualPracticeAlchemyClassifier.GetKind(item)!.Value;
                                var rpaCost = FormatItemCost(item);
                                <li>
                                    <button @onclick="() => AddRitualPracticeAlchemyItem(item)"
                                            class="w-full text-left px-3 py-2 hover:bg-surface-container-low/60 transition-colors flex items-center justify-between gap-3">
                                        <div class="min-w-0 flex-1">
                                            <div class="text-sm font-bold text-on-surface truncate">@item.Name</div>
                                            <div class="text-[10px] text-outline uppercase tracking-wider">
                                                @FormatRitualPracticeAlchemyKind(kind)
                                                @if (item.Fields.TryGetValue("Level", out var level) && !string.IsNullOrWhiteSpace(level))
                                                {
                                                    <span> — Level @level</span>
                                                }
                                                @if (item.Source is not null)
                                                {
                                                    <span> — @item.Source</span>
                                                }
