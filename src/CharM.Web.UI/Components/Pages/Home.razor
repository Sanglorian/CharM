                        <div class="flex items-center gap-1.5 text-on-surface-variant ml-auto">
                            <span>Sort:</span>
                            <select @bind="_equipSortMode"
                                    class="bg-surface-container-low border-b border-outline rounded px-1.5 py-0.5 text-on-surface focus:border-primary focus:outline-none">
                                <option value="level">Level</option>
                                <option value="proficiency">Proficient first</option>
                                <option value="name">Name</option>
                                <option value="damage">Damage / AC</option>
                                <option value="price">Price</option>
                            </select>
                        </div>
                    </div>
                </div>
                <!-- Content -->
                <div class="flex flex-1 min-h-0">
                    <!-- Left: Item List -->
                    <div class="w-2/5 border-r border-outline-variant/20 overflow-y-auto">
                        <table class="w-full text-sm">
                            <thead class="sticky top-0 bg-surface-container-low z-10">
                                <tr>
                                    <th class="text-left px-3 py-2 text-[10px] font-label font-semibold uppercase tracking-wider text-on-surface-variant">Name</th>
                                    <th class="text-left px-2 py-2 text-[10px] font-label font-semibold uppercase tracking-wider text-on-surface-variant">@PrimaryStatHeader</th>
                                    <th class="text-left px-2 py-2 text-[10px] font-label font-semibold uppercase tracking-wider text-on-surface-variant">Group</th>
                                    <th class="text-center px-1 py-2 text-[10px] font-label font-semibold uppercase tracking-wider text-on-surface-variant" title="Proficient">P</th>
