                            @if (_selectedEquipDetail.Fields.TryGetValue("Special", out var spc) && !string.IsNullOrWhiteSpace(spc))
                            {
                                <div class="mt-3">
                                    <span class="text-xs font-label font-semibold uppercase tracking-wider text-on-surface-variant">Special</span>
                                    <p class="text-sm text-on-surface mt-0.5 whitespace-pre-line">@spc</p>
