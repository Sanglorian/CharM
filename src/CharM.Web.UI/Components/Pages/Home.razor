                            @if (_selectedEquipDetail.Fields.TryGetValue("Property", out var prop) && !string.IsNullOrWhiteSpace(prop))
                            {
                                <div class="mt-3">
                                    <span class="text-xs font-label font-semibold uppercase tracking-wider text-on-surface-variant">Property</span>
                                    <p class="text-sm text-on-surface mt-0.5 whitespace-pre-line">@prop</p>
