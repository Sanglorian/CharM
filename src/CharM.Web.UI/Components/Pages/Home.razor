    private void ConfirmMagicComposite(LootItem composite)
    {
        var session = SessionService.Session;
        if (session is null) return;

        if (_magicBuilderTargetSlot is not null)
        {
            // Mirror the 2H rules from ConfirmEquipment so the composite path
            // matches the mundane equip path:
            //  • A 2H base always goes into Main Hand and clears Off-Hand.
            //  • Equipping into Off-Hand while a 2H is in Main Hand frees Main Hand.
            if (IsTwoHandedWeapon(composite.Base))
            {
                session.UnequipItem("Off-Hand");
                session.EquipItem("Main Hand", composite);
            }
            else if (string.Equals(_magicBuilderTargetSlot, "Off-Hand", StringComparison.OrdinalIgnoreCase)
                     && session.GetEquippedItem("Main Hand") is { } current
                     && IsTwoHandedWeapon(current))
            {
                session.UnequipItem("Main Hand");
                session.EquipItem(_magicBuilderTargetSlot, composite);
            }
            else
            {
                session.EquipItem(_magicBuilderTargetSlot, composite);
            }
        }
        else
        {
            session.AddInventoryItem(composite, 1);
        }
    }

    private static bool IsTwoHandedWeapon(RulesElement item)
    {
        if (!string.Equals(item.Type, "Weapon", StringComparison.OrdinalIgnoreCase))
            return false;

        return item.Fields.TryGetValue("Hands Required", out var hands)
               && !string.IsNullOrWhiteSpace(hands)
               && hands.Contains("Two-Handed", StringComparison.OrdinalIgnoreCase);
    }

    private bool IsOffHandBlockedByTwoHanded()
    {
        var mainHand = SessionService.Session?.GetEquippedItem("Main Hand");
        return mainHand is not null && IsTwoHandedWeapon(mainHand);
    }

