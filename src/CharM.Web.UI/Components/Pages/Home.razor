    private IReadOnlyList<RulesElement> FilteredInventoryCandidates
    {
        get
        {
            var src = _inventoryCandidates ?? Array.Empty<RulesElement>();
            if (string.IsNullOrWhiteSpace(_inventorySearchText))
                return src.OrderBy(c => c.Name, StringComparer.OrdinalIgnoreCase).ToList();
            return src.Where(c =>
                c.Name.Contains(_inventorySearchText, StringComparison.OrdinalIgnoreCase) ||
                c.Type.Contains(_inventorySearchText, StringComparison.OrdinalIgnoreCase) ||
                (c.Source?.Contains(_inventorySearchText, StringComparison.OrdinalIgnoreCase) ?? false))
              .OrderBy(c => c.Name, StringComparer.OrdinalIgnoreCase)
              .ToList();
        }
    }

    private IReadOnlyList<RulesElement> FilteredRitualPracticeAlchemyCandidates
    {
        get
        {
            IEnumerable<RulesElement> q = _ritualPracticeAlchemyCandidates ?? Array.Empty<RulesElement>();

            if (!string.IsNullOrWhiteSpace(_ritualPracticeAlchemyKindFilter)
                && Enum.TryParse<RitualPracticeAlchemyKind>(_ritualPracticeAlchemyKindFilter, out var selectedKind))
            {
                q = q.Where(c => RitualPracticeAlchemyClassifier.GetKind(c) == selectedKind);
            }

            if (!string.IsNullOrWhiteSpace(_ritualPracticeAlchemySearchText))
            {
                q = q.Where(c =>
                    c.Name.Contains(_ritualPracticeAlchemySearchText, StringComparison.OrdinalIgnoreCase) ||
                    c.Type.Contains(_ritualPracticeAlchemySearchText, StringComparison.OrdinalIgnoreCase) ||
                    FormatRitualPracticeAlchemyKind(RitualPracticeAlchemyClassifier.GetKind(c)!.Value)
                        .Contains(_ritualPracticeAlchemySearchText, StringComparison.OrdinalIgnoreCase) ||
                    (c.Source?.Contains(_ritualPracticeAlchemySearchText, StringComparison.OrdinalIgnoreCase) ?? false));
            }

            return q
                .OrderBy(c => RitualPracticeAlchemyClassifier.KindSortKey(RitualPracticeAlchemyClassifier.GetKind(c)!.Value))
                .ThenBy(c => LevelSortKey(c))
                .ThenBy(c => c.Name, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
    }

    private IReadOnlyList<RulesElement> FilteredEquipment
    {
        get
        {
            var src = _equipmentCandidates ?? Array.Empty<RulesElement>();
            IEnumerable<RulesElement> q = src;

            if (!string.IsNullOrWhiteSpace(_equipSearchText))
            {
                q = q.Where(c =>
                    c.Name.Contains(_equipSearchText, StringComparison.OrdinalIgnoreCase) ||
                    c.Type.Contains(_equipSearchText, StringComparison.OrdinalIgnoreCase) ||
                    GroupOrType(c).Contains(_equipSearchText, StringComparison.OrdinalIgnoreCase) ||
                    (c.Source?.Contains(_equipSearchText, StringComparison.OrdinalIgnoreCase) ?? false));
            }

            if (_equipOnlyProficient)
                q = q.Where(c => SessionService.IsProficientWith(c));

            // Two-handed weapons can't go into the Off-Hand slot — they're
            // wielded with both hands, by the Main Hand entry. Filtering
            // here prevents the user from picking a 2H weapon for Off-Hand
            // and matches the OCB equip behavior.
            if (string.Equals(_activeEquipSlot, "Off-Hand", StringComparison.OrdinalIgnoreCase))
                q = q.Where(c => !IsTwoHandedWeapon(c));

            q = _equipSortMode switch
            {
                "name"     => q.OrderBy(c => c.Name, StringComparer.OrdinalIgnoreCase),
                "damage"   => q.OrderByDescending(c => DamageOrAcSortKey(c))
                               .ThenBy(c => c.Name, StringComparer.OrdinalIgnoreCase),
                "price"    => q.OrderBy(c => ParseGoldPrice(c))
                               .ThenBy(c => c.Name, StringComparer.OrdinalIgnoreCase),
                "level"    => q.OrderBy(c => LevelSortKey(c))
                               .ThenBy(c => c.Name, StringComparer.OrdinalIgnoreCase),
                _          => q.OrderByDescending(c => SessionService.IsProficientWith(c))
                               .ThenBy(c => c.Name, StringComparer.OrdinalIgnoreCase),
            };

            return q.ToList();
        }
    }

    private string PrimaryStatHeader
    {
        get
        {
            // Heuristic: weapons → Damage; armor → AC; gear → Slot.
            var sample = (_equipmentCandidates ?? Array.Empty<RulesElement>()).FirstOrDefault();
            if (sample is null) return "Stat";
            if (string.Equals(sample.Type, "Weapon", StringComparison.OrdinalIgnoreCase)) return "Damage";
            if (string.Equals(sample.Type, "Armor", StringComparison.OrdinalIgnoreCase)) return "AC";
            return "Slot";
        }
    }

    private static string PrimaryStatValue(RulesElement item)
    {
        if (string.Equals(item.Type, "Weapon", StringComparison.OrdinalIgnoreCase)
            && item.Fields.TryGetValue("Damage", out var d) && !string.IsNullOrWhiteSpace(d))
            return d;
        if (string.Equals(item.Type, "Armor", StringComparison.OrdinalIgnoreCase)
            && item.Fields.TryGetValue("Armor Bonus", out var ab) && !string.IsNullOrWhiteSpace(ab))
            return $"+{ab}";
        if (item.Fields.TryGetValue("Item Slot", out var slot) && !string.IsNullOrWhiteSpace(slot))
            return slot;
        return "";
    }

    private static string GroupOrType(RulesElement item)
    {
        if (item.Fields.TryGetValue("Group", out var g) && !string.IsNullOrWhiteSpace(g))
            return g;
        if (item.Fields.TryGetValue("Armor Type", out var at) && !string.IsNullOrWhiteSpace(at))
            return at;
        if (item.Fields.TryGetValue("Weapon Category", out var wc) && !string.IsNullOrWhiteSpace(wc))
            return wc;
        return item.Type;
    }

    private static int DamageOrAcSortKey(RulesElement item)
    {
        // Sort weapons by max damage die rank, armors by armor bonus.
        if (item.Fields.TryGetValue("Damage", out var d) && !string.IsNullOrWhiteSpace(d))
        {
            // "1d8", "2d6", "1d10" — use sides * count as proxy.
            var m = System.Text.RegularExpressions.Regex.Match(d, @"(\d+)d(\d+)");
            if (m.Success && int.TryParse(m.Groups[1].Value, out var n) && int.TryParse(m.Groups[2].Value, out var s))
                return n * s;
        }
        if (item.Fields.TryGetValue("Armor Bonus", out var ab) && int.TryParse(ab, out var v))
            return v;
        return 0;
    }

    private static int ParseInt(IReadOnlyDictionary<string, string> fields, string key)
        => fields.TryGetValue(key, out var s) && int.TryParse(s, out var i) ? i : 0;

    private static int LevelSortKey(RulesElement item)
        => item.Fields.TryGetValue("Level", out var s) && int.TryParse(s, out var i) ? i : int.MaxValue;

    private static string RitualPracticeAlchemyMeta(RitualPracticeAlchemyEntry row)
    {
        var parts = new List<string>();
        if (row.Element.Fields.TryGetValue("Level", out var level) && !string.IsNullOrWhiteSpace(level))
            parts.Add($"L{level}");
        if (!row.IsInventoryItem && row.Quantity == 0)
            parts.Add("granted");
        return parts.Count == 0 ? "" : "(" + string.Join(", ", parts) + ")";
    }

    private static string FormatRitualPracticeAlchemyKind(RitualPracticeAlchemyKind kind)
        => kind switch
        {
            RitualPracticeAlchemyKind.Ritual => "Rituals",
            RitualPracticeAlchemyKind.RitualScroll => "Ritual Scrolls",
            RitualPracticeAlchemyKind.AlchemicalFormula => "Alchemical Formulae",
            RitualPracticeAlchemyKind.AlchemicalItem => "Alchemical Items",
            RitualPracticeAlchemyKind.PoisonRecipe => "Poison Recipes",
            RitualPracticeAlchemyKind.MartialPractice => "Martial Practices",
            _ => kind.ToString(),
        };

    private static int ParseGoldPrice(RulesElement item)
    {
        if (!item.Fields.TryGetValue("Gold", out var p) || string.IsNullOrWhiteSpace(p))
            return int.MaxValue; // unpriced items go last
        var m = System.Text.RegularExpressions.Regex.Match(p, @"([\d,]+)");
        if (m.Success && int.TryParse(m.Groups[1].Value.Replace(",", ""), out var v))
            return v;
        return int.MaxValue;
    }

    /// <summary>
    /// Display string for an item's purchase cost, suitable for the
    /// inventory and ritual add modals. Returns null when the rules
    /// element has no Gold field (or the field is blank).
    /// </summary>
    private static string? FormatItemCost(RulesElement item)
    {
        if (!item.Fields.TryGetValue("Gold", out var gold) || string.IsNullOrWhiteSpace(gold))
            return null;

        var trimmed = gold.Trim();
        // Most rules entries already include the currency suffix; only
        // append "gp" for bare numerics (e.g. "50" → "50 gp").
        if (System.Text.RegularExpressions.Regex.IsMatch(trimmed, @"^[\d,]+(\.\d+)?$"))
            return $"{trimmed} gp";
        return trimmed;
    }

    // Ordered for display: most-relevant first.
    private static readonly string[] _equipmentDisplayFieldOrder =
    [
        // Magic-item summary
        "Enhancement", "Critical", "Magic Item Type", "Rarity", "Weapon",
        // Combat stats
        "Damage", "Proficiency Bonus", "Hands Required", "Range",
        "Armor Bonus", "Armor Type", "Armor Category", "Check", "Speed",
        // Misc
        "Group", "Weapon Category", "Properties",
        // Slot / cost / weight
        "Item Slot", "Level", "Gold", "Weight",
    ];

    private static readonly Dictionary<string, string> _fieldDisplayLabels = new(StringComparer.OrdinalIgnoreCase)
    {
        ["Gold"] = "Cost (gp)",
        ["Weapon"] = "Applies to",
    };

    private static IReadOnlyList<KeyValuePair<string, string>> GetEquipmentDetailFields(RulesElement element)
    {
        var result = new List<KeyValuePair<string, string>>();
        foreach (var key in _equipmentDisplayFieldOrder)
        {
            if (!element.Fields.TryGetValue(key, out var v) || string.IsNullOrWhiteSpace(v))
                continue;
            var label = _fieldDisplayLabels.TryGetValue(key, out var l) ? l : key;
            result.Add(new KeyValuePair<string, string>(label, v.Trim()));
        }
        return result;
    }

    private static IReadOnlyList<(string Name, string Value)> GetEquipmentSummary(RulesElement element)
    {
        var summary = new List<(string, string)>();
        if (element.Fields.TryGetValue("Enhancement", out var enh) && !string.IsNullOrEmpty(enh))
            summary.Add(("Enh", $"+{enh}"));
        if (element.Fields.TryGetValue("Damage", out var dmg) && !string.IsNullOrEmpty(dmg))
            summary.Add(("Dmg", dmg));
        if (element.Fields.TryGetValue("Armor Bonus", out var ab) && !string.IsNullOrEmpty(ab))
            summary.Add(("AC", $"+{ab}"));
        if (element.Fields.TryGetValue("Proficiency Bonus", out var prof) && !string.IsNullOrEmpty(prof))
            summary.Add(("Prof", $"+{prof}"));
        return summary;
    }

    // --- Class Feature grouping for intermediate elements ---

    private sealed record GrantLink(string Label, string InternalId);
    private sealed record FeatureGroup(RulesElement Parent, List<RulesElement> Children, List<GrantLink> GrantLinks);

    private List<FeatureGroup> GroupClassFeatures(IReadOnlyList<RulesElement> features)
    {
        // Build a set of all feature IDs for quick lookup
        var featureIds = new HashSet<string>(
            features.Select(f => f.InternalId).Where(id => id is not null)!,
            StringComparer.OrdinalIgnoreCase);

        // Find intermediates that have same-type children in this list
        // A child belongs to a parent if its Categories contain the parent's InternalId
        var childToParent = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        foreach (var feature in features)
        {
            foreach (var cat in feature.Categories)
            {
                if (featureIds.Contains(cat))
                {
                    childToParent[feature.InternalId] = cat;
                    break;
                }
            }
        }

        // Build parent -> children map
        var parentChildren = new Dictionary<string, List<RulesElement>>(StringComparer.OrdinalIgnoreCase);
        foreach (var (childId, parentId) in childToParent)
        {
            if (!parentChildren.TryGetValue(parentId, out var list))
            {
                list = [];
                parentChildren[parentId] = list;
            }
            list.Add(features.First(f => string.Equals(f.InternalId, childId, StringComparison.OrdinalIgnoreCase)));
        }

        var result = new List<FeatureGroup>();
        foreach (var feature in features)
        {
            // Skip children — they'll appear under their parent
            if (childToParent.ContainsKey(feature.InternalId))
                continue;

            if (parentChildren.TryGetValue(feature.InternalId, out var children))
            {
                // Intermediate with same-type children → header group
                result.Add(new FeatureGroup(feature, children, []));
            }
            else
            {
                // Check if it's a grant-only intermediate that should get synthesized links
                var grantLinks = SynthesizeGrantLinks(feature);
                result.Add(new FeatureGroup(feature, [], grantLinks));
            }
        }

        return result;
    }

    /// <summary>
    /// For intermediate elements (only grant/select directives), synthesize
    /// clickable links to granted elements, e.g. "You can use Wild Shape"
    /// or "You gain the Defensive Mobility feat".
    /// Returns empty list for non-intermediate elements.
    /// </summary>
    private List<GrantLink> SynthesizeGrantLinks(RulesElement feature)
    {
        var detail = SessionService.GetElementDetails(feature.InternalId);
        if (detail is null || detail.Rules.Count == 0)
            return [];

        bool allStructural = detail.Rules.All(r => r is GrantDirective or SelectDirective);
        if (!allStructural)
            return [];

        var links = new List<GrantLink>();
        foreach (var rule in detail.Rules)
        {
            if (rule is GrantDirective grant)
            {
                var grantedElement = SessionService.GetElementDetails(grant.Name);
                if (grantedElement is null) continue;
                if (grantedElement.Type.Equals("Internal", StringComparison.OrdinalIgnoreCase)
                    || grantedElement.Type.Equals("Grants", StringComparison.OrdinalIgnoreCase)
                    || grantedElement.Type.Equals("CountsAsFeature", StringComparison.OrdinalIgnoreCase))
                    continue;

                links.Add(new GrantLink(FormatGrantedElement(grantedElement), grantedElement.InternalId));
            }
        }

        return links;
    }

    private static string FormatGrantedElement(RulesElement element)
    {
        return element.Type switch
        {
            "Power" => $"You can use {element.Name}",
            "Feat" => $"You gain the {element.Name} feat",
            "Proficiency" => $"You gain proficiency with {element.Name}",
            _ => $"You gain {element.Name}",
        };
    }

    private void HandleSessionChanged()
    {
        _lastAutoResolveChoiceCount = -1;
        _lastAutoResolvePendingCount = -1;
        _lastAutoResolveScoresSet = false;
        UpdateCompleteToast(SessionService.Session?.IsComplete == true);
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        SessionService.Changed -= HandleSessionChanged;
        RestoreState.Changed -= HandleSessionChanged;
        CancelCompleteToastTimer();
    }

    private void UpdateCompleteToast(bool isComplete)
    {
        if (!isComplete)
        {
            _lastCompleteState = false;
            _showCompleteToast = false;
            CancelCompleteToastTimer();
            return;
        }

        if (_lastCompleteState)
            return;

        _lastCompleteState = true;
        _showCompleteToast = true;
        RestartCompleteToastTimer();
    }

    private void RestartCompleteToastTimer()
    {
        CancelCompleteToastTimer();
        _completeToastCts = new CancellationTokenSource();
        _ = HideCompleteToastAfterDelayAsync(_completeToastCts.Token);
    }

    private async Task HideCompleteToastAfterDelayAsync(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(TimeSpan.FromSeconds(2), cancellationToken);
            if (cancellationToken.IsCancellationRequested)
                return;

            _showCompleteToast = false;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void CancelCompleteToastTimer()
    {
        if (_completeToastCts is null)
            return;

        _completeToastCts.Cancel();
        _completeToastCts.Dispose();
        _completeToastCts = null;
    }
}
