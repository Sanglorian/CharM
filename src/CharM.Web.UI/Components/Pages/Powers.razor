}

@code {
    private bool _printCardsView;
    private string _sortMode = "level";
    private bool _sortMenuOpen;
    private bool _viewMenuOpen;
    private bool _basicPowersExpanded;
    private readonly HashSet<string> _collapsedCards = new(StringComparer.OrdinalIgnoreCase);

    private void ToggleCardCollapsed(string internalId)
    {
        if (string.IsNullOrEmpty(internalId)) return;
        if (!_collapsedCards.Add(internalId))
            _collapsedCards.Remove(internalId);
    }

    private bool IsCardCollapsed(string internalId)
        => !string.IsNullOrEmpty(internalId) && _collapsedCards.Contains(internalId);

    private void ToggleSortMenu()
    {
        _sortMenuOpen = !_sortMenuOpen;
        if (_sortMenuOpen) _viewMenuOpen = false;
    }

    private void ToggleViewMenu()
    {
        _viewMenuOpen = !_viewMenuOpen;
        if (_viewMenuOpen) _sortMenuOpen = false;
    }

    private void ToggleBasicPowers()
        => _basicPowersExpanded = !_basicPowersExpanded;

    private void CloseMenus()
    {
        _sortMenuOpen = false;
        _viewMenuOpen = false;
    }

    private void SelectSort(string mode)
    {
        _sortMode = mode;
        _sortMenuOpen = false;
    }

    private void SelectPrintMode(bool printView)
    {
        _printCardsView = printView;
        _viewMenuOpen = false;
    }

    private static string SortLabel(string mode) => mode switch
    {
        "name" => "Name",
        "used" => "Unused",
        _ => "Level",
    };

    private IEnumerable<PowerDisplayCard> SortPowers(IEnumerable<PowerDisplayCard> cards) => _sortMode switch
    {
        "name" => cards.OrderBy(c => c.Name, StringComparer.OrdinalIgnoreCase),
        "used" => cards
            .OrderBy(c => IsPowerUsed(c.InternalId) ? 1 : 0)
            .ThenBy(c => c.Level)
            .ThenBy(c => c.Name, StringComparer.OrdinalIgnoreCase),
        _ => cards.OrderBy(c => c.Level).ThenBy(c => c.Name, StringComparer.OrdinalIgnoreCase),
    };
    private bool _showModal;
    private PendingChoice? _activeChoice;
    private IReadOnlyList<RulesElement>? _modalCandidates;
    private readonly HashSet<string> _usedPowers = new(StringComparer.OrdinalIgnoreCase);
    private bool _bodyClassApplied;
    private long _usedPowersSessionVersion = -1;

    protected override void OnInitialized()
    {
        _usedPowersSessionVersion = SessionService.SessionVersion;
        SessionService.Changed += HandleSessionChanged;
    }

    private IReadOnlyList<PendingChoice> GetPendingPowerChoices(CharacterSession session)
        => session.GetAllPendingChoices()
            .Where(choice => choice.Slot.ElementType.Equals("Power", StringComparison.OrdinalIgnoreCase))
            .Select((choice, index) => new { choice, index })
            .OrderBy(item => item.choice.Slot.Optional ? 1 : 0)
            .ThenBy(item => item.index)
            .Select(item => item.choice)
            .ToList();

    private static IReadOnlyList<PendingChoice> GetPendingChoicesForSection(
        IReadOnlyList<PendingChoice> pendingChoices,
        string section)
        => pendingChoices.Where(choice => DetermineSection(choice) == section).ToList();

    private IReadOnlyList<PowerDisplayCard> BuildPowerCards(
        CharacterSession session,
        CharacterSnapshot? snapshot,
        IReadOnlyList<CharM.Serialization.PowerStatEntry> powerStats)
    {
        var stats = snapshot?.Builder.Stats;
        var cantripIds = CollectCantripPowerIds(snapshot);

        var powers = GetDisplayPowers(session, snapshot)
            .Where(power => !PowerCardFactory.IsFamiliarCardPower(power))
            .Where(power => !IsAugmentVariant(power));

        return PowerCardFactory.BuildSessionCards(
            powers,
            stats,
            powerStats,
            session.IsHouseruledElement,
            sectionOverride: power =>
            {
                if (!string.IsNullOrEmpty(power.InternalId)
                    && cantripIds.Contains(power.InternalId))
                {
                    return PowerSectionKeys.Cantrip;
                }

                return null;
            },
            augmentVersions: GetAugmentVersions);
    }

    private IEnumerable<RulesElement> GetDisplayPowers(CharacterSession session, CharacterSnapshot? snapshot)
    {
        var seen = new HashSet<string>(StringComparer.Ordinal);

        if (snapshot is not null)
        {
            foreach (var node in snapshot.Builder.ElementTree.Root.GetAllDescendants())
            {
                if (node.RulesElement is not { } power) continue;
                if (!power.Type.Equals("Power", StringComparison.OrdinalIgnoreCase)) continue;
                if (IsAugmentVariant(power)) continue;
                if (!string.IsNullOrEmpty(power.InternalId)
                    && (snapshot.PowerStatsExcludedIds.Contains(power.InternalId)
                        || snapshot.LevelNestedOnlyIds.Contains(power.InternalId)))
                {
                    continue;
                }

                var key = !string.IsNullOrEmpty(power.InternalId)
                    ? power.InternalId
                    : "name:" + power.Name;
                if (!seen.Add(key)) continue;

                yield return !string.IsNullOrEmpty(power.InternalId)
                    ? SessionService.GetElementDetails(power.InternalId) ?? power
                    : power;
            }

            yield break;
        }

        foreach (var power in session.GetAllElementsOfType("Power"))
        {
            if (IsAugmentVariant(power)) continue;
            var key = !string.IsNullOrEmpty(power.InternalId)
                ? power.InternalId
                : "name:" + power.Name;
            if (seen.Add(key))
                yield return !string.IsNullOrEmpty(power.InternalId)
                    ? SessionService.GetElementDetails(power.InternalId) ?? power
                    : power;
        }
    }

    /// <summary>
    /// Detect companion/beast powers that should be grouped in a separate section.
    /// </summary>
    private static bool IsCompanionPowerCard(PowerDisplayCard card)
        => card.InternalId.StartsWith("ID_TIV_COMPANION-", StringComparison.OrdinalIgnoreCase)
        || card.InternalId.StartsWith("ID_TIV_ANIMAL_COMPANION-", StringComparison.OrdinalIgnoreCase)
        || card.InternalId.StartsWith("ID_INTERNAL_POWER_BEAST_", StringComparison.OrdinalIgnoreCase)
        || card.Name.StartsWith("Companion:", StringComparison.OrdinalIgnoreCase)
        || card.Name.StartsWith("Animal Master's Companion:", StringComparison.OrdinalIgnoreCase)
        || card.Name.StartsWith("Animal Companion:", StringComparison.OrdinalIgnoreCase)
        || card.Name.StartsWith("Beast ", StringComparison.OrdinalIgnoreCase);

    /// <summary>
    /// Channel Divinity powers are tagged with a "Channel Divinity" field
    /// containing the standard once-per-encounter restriction text. They
    /// share a single per-encounter use across all such powers, so we render
    /// them in a dedicated section instead of mixing into Encounter Powers.
    /// </summary>
    private bool IsChannelDivinityCard(PowerDisplayCard card)
    {
        var detail = SessionService.GetElementDetails(card.InternalId);
        return detail is not null && detail.Fields.ContainsKey("Channel Divinity");
    }

    /// <summary>
    /// Drop OCB-export placeholder companion entries and dedupe by anchor
    /// power id so display surfaces (mini-sheet + attack card grouping)
    /// render one row per real companion. <see
    /// cref="CharM.Engine.Creation.CharacterSession.GetCompanionData"/>
    /// returns one entry per active "Companion" CharElement (one per level
    /// for animal companions) because the .dnd4e writer needs that fan-out
    /// for OCB &lt;Beast&gt; block parity. The UI must not honor that fan-out.
    /// </summary>
    private static IReadOnlyList<CompanionData> DedupeCompanionDataForDisplay(IReadOnlyList<CompanionData> source)
    {
        if (source.Count == 0) return source;
        var seenAnchors = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var result = new List<CompanionData>(source.Count);
        foreach (var beast in source)
        {
            if (beast.IsPlaceholderForActiveBeast) continue;
            if (!string.IsNullOrEmpty(beast.AnchorPowerInternalId)
                && !seenAnchors.Add(beast.AnchorPowerInternalId))
            {
                continue;
            }
            result.Add(beast);
        }
        return result;
    }

    /// <summary>Generic beast attack stub that's redundant when a Companion: X card is present.</summary>
    private static bool IsGenericBeastAttack(PowerDisplayCard card)
        => card.InternalId.StartsWith("ID_INTERNAL_POWER_BEAST_", StringComparison.OrdinalIgnoreCase)
        || card.Name.Equals("Beast Melee Basic Attack", StringComparison.OrdinalIgnoreCase)
        || card.Name.Equals("Beast Ranged Basic Attack", StringComparison.OrdinalIgnoreCase);

    /// <summary>
    /// Wizard spellbook: how many daily/utility powers can be prepared per day.
    /// From the PHB Wizard Powers Prepared per Day table.
    /// </summary>
    private static int GetSpellbookPreparedCount(int level) => level switch
    {
        >= 25 => 4,
        >= 15 => 3,
        >= 5 => 2,
        _ => 1,
    };

    private IReadOnlyList<RulesElement> GetAugmentVersions(RulesElement power)
    {
        if (!power.Fields.TryGetValue("_AugmentVersions", out var raw) || string.IsNullOrWhiteSpace(raw))
            return [];

        var variants = new List<RulesElement>();
        foreach (var id in raw.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            var variant = SessionService.GetElementDetails(id);
            if (variant is not null)
                variants.Add(variant);
        }

        return variants;
    }

    private static bool IsAugmentVariant(RulesElement power)
        => power.Fields.ContainsKey("_AugmentParent");

    private static bool IsBasicPowerCard(PowerDisplayCard card)
        => IsBasicPower(card.InternalId, card.Name);

    private static bool IsBasicPower(string internalId, string name)
    {
        if (internalId.Equals("ID_INTERNAL_POWER_MELEE_BASIC_ATTACK", StringComparison.OrdinalIgnoreCase)
            || internalId.Equals("ID_INTERNAL_POWER_RANGED_BASIC_ATTACK", StringComparison.OrdinalIgnoreCase)
            || internalId.Equals("ID_INTERNAL_POWER_BULL_RUSH_ATTACK", StringComparison.OrdinalIgnoreCase)
            || internalId.Equals("ID_INTERNAL_POWER_GRAB_ATTACK", StringComparison.OrdinalIgnoreCase)
            || internalId.Equals("ID_INTERNAL_POWER_OPPORTUNITY_ATTACK", StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        return name.Equals("Melee Basic Attack", StringComparison.OrdinalIgnoreCase)
            || name.Equals("Ranged Basic Attack", StringComparison.OrdinalIgnoreCase)
            || name.Equals("Bull Rush Attack", StringComparison.OrdinalIgnoreCase)
            || name.Equals("Grab Attack", StringComparison.OrdinalIgnoreCase)
            || name.Equals("Opportunity Attack", StringComparison.OrdinalIgnoreCase);
    }

    private static IReadOnlyList<PowerDisplayCard> BuildMagicItemPowerCards(CharacterSession session)
    {
        var cards = new List<PowerDisplayCard>();
        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        void AddLoot(LootItem loot)
        {
            foreach (var component in loot.Components())
            {
                if (!component.Type.Equals("Magic Item", StringComparison.OrdinalIgnoreCase))
                    continue;

                foreach (var card in PowerCardFactory.BuildItemPowerCards(component, PowerSectionKeys.MagicItem))
                {
                    if (seen.Add(card.InternalId))
                        cards.Add(card);
                }
            }
        }

        foreach (var loot in session.GetEquippedLoot().Values)
            AddLoot(loot);

        foreach (var inventoryItem in session.GetInventory().Where(item => item.Quantity >= 1))
            AddLoot(inventoryItem.Item);

        return cards;
    }

    private void OpenSelectionModal(PendingChoice choice)
    {
        _activeChoice = choice;
        _modalCandidates = SessionService.Session!.GetCandidatesForSlot(choice.Slot);
        _showModal = true;
    }

    private void OnElementSelected(RulesElement element)
    {
        if (_activeChoice is null)
            return;

        SessionService.Session!.MakeChoice(_activeChoice.Slot, element);
        CloseModal();
    }

    private void CloseModal()
    {
        _showModal = false;
        _activeChoice = null;
        _modalCandidates = null;
    }

    private RulesElement? LoadElementDetails(string internalId)
        => SessionService.GetElementDetails(internalId);

    private List<ResolvedElement> ResolveElementIds(string idList)
        => SessionService.ResolveElementIds(idList);

    private bool IsPowerUsed(string internalId)
        => _usedPowers.Contains(internalId);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || _bodyClassApplied != _printCardsView)
        {
            _bodyClassApplied = _printCardsView;
            await JS.InvokeVoidAsync("charm.setBodyClass", "view-print-cards", _printCardsView);
        }
    }

    private ChoiceRecord? FindChoiceRecord(string internalId)
        => SessionService.Session?.ChoiceHistory
            .LastOrDefault(record => string.Equals(record.Element.InternalId, internalId, StringComparison.OrdinalIgnoreCase));

    private void OnPowerUsageChanged(string internalId, ChangeEventArgs args)
    {
        _usedPowersSessionVersion = SessionService.SessionVersion;
        bool isUsed = string.Equals(args.Value?.ToString(), "true", StringComparison.OrdinalIgnoreCase);
        if (isUsed)
            _usedPowers.Add(internalId);
        else
            _usedPowers.Remove(internalId);
    }

    private void BeginReselect(ChoiceRecord record)
    {
        var session = SessionService.Session;
        if (session is null)
            return;

        session.RemoveChoice(record);

        var replacement = SessionService.FindReplacementChoice(record);
        if (replacement is not null)
        {
            OpenSelectionModal(replacement);
        }
        else
        {
            CloseModal();
        }
    }

    private static string DetermineSection(PendingChoice choice)
    {
        string description = choice.Description;
        if (description.Contains("Utility", StringComparison.OrdinalIgnoreCase))
            return PowerSectionKeys.Utility;
        if (description.Contains("Daily", StringComparison.OrdinalIgnoreCase))
            return PowerSectionKeys.Daily;
        if (description.Contains("Encounter", StringComparison.OrdinalIgnoreCase))
            return PowerSectionKeys.Encounter;
        return PowerSectionKeys.AtWill;
    }

    /// <summary>
    /// Walk the engine tree and return the InternalIds of every Power whose
    /// owning select slot is a Class Feature with "Cantrip" in its name.
    ///
    /// <para>Six known cantrip-granting class features ship in the rules DB
    /// (Arcanist Cantrips, Mage Cantrips, Bladesinger Cantrips, Hybrid
    /// Cantrips, Sha'ir Cantrips, Witch Cantrips); rather than hard-coding
    /// any of those internal-ids we use the live <see cref="CharacterElement.SlotOwnerInternalId"/>
    /// which the wizard stamps on every picked element with the InternalId
    /// of whatever opened its select slot. Cross-referenced category IDs
    /// (a Wizard pick under <c>Arcanist Cantrips</c> resolves to candidates
    /// in the <c>Mage Cantrips</c> category) don't break this signal because
    /// the slot owner is always the actual feature that opened the slot,
    /// regardless of which feature defines the candidate category.</para>
    /// </summary>
    private static HashSet<string> CollectCantripPowerIds(CharacterSnapshot? snapshot)
    {
        var ids = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        if (snapshot is null) return ids;

        var featureNamesById = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        foreach (var node in snapshot.Builder.ElementTree.Root.GetAllDescendants())
        {
            if (node.RulesElement is not { } el) continue;
            if (!el.Type.Equals("Class Feature", StringComparison.OrdinalIgnoreCase)) continue;
            if (string.IsNullOrEmpty(el.InternalId)) continue;
            featureNamesById[el.InternalId] = el.Name;
        }

        foreach (var node in snapshot.Builder.ElementTree.Root.GetAllDescendants())
        {
            if (node.RulesElement is not { } power) continue;
            if (!power.Type.Equals("Power", StringComparison.OrdinalIgnoreCase)) continue;
            if (string.IsNullOrEmpty(power.InternalId)) continue;
            if (string.IsNullOrEmpty(node.SlotOwnerInternalId)) continue;
            if (!featureNamesById.TryGetValue(node.SlotOwnerInternalId, out var ownerName)) continue;
            if (ownerName.IndexOf("Cantrip", StringComparison.OrdinalIgnoreCase) < 0) continue;
            ids.Add(power.InternalId);
        }
        return ids;
    }

    /// <summary>
    /// Return the map Power.InternalId -&gt; "Tome of *" Class Feature name
    /// for every encounter power stored by a tome implement mastery on the
    /// character. Detected via <see cref="CharacterElement.SlotOwnerInternalId"/>
    /// matching a Class Feature whose name starts with "Tome of " — the
    /// same slot-owner signal used for cantrip detection. Surfaced as an
    /// inline notice directly above the matching encounter card.
    /// </summary>
    private static Dictionary<string, string> CollectTomeStoredPowerMap(CharacterSnapshot? snapshot)
    {
        var map = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        if (snapshot is null) return map;

        var tomeFeatureNamesById = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        foreach (var node in snapshot.Builder.ElementTree.Root.GetAllDescendants())
        {
            if (node.RulesElement is not { } el) continue;
            if (!el.Type.Equals("Class Feature", StringComparison.OrdinalIgnoreCase)) continue;
            if (!el.Name.StartsWith("Tome of ", StringComparison.OrdinalIgnoreCase)) continue;
            if (!string.IsNullOrEmpty(el.InternalId))
                tomeFeatureNamesById[el.InternalId] = el.Name;
        }
        if (tomeFeatureNamesById.Count == 0) return map;

        foreach (var node in snapshot.Builder.ElementTree.Root.GetAllDescendants())
        {
            if (node.RulesElement is not { } power) continue;
            if (!power.Type.Equals("Power", StringComparison.OrdinalIgnoreCase)) continue;
            if (string.IsNullOrEmpty(power.InternalId)) continue;
            if (string.IsNullOrEmpty(node.SlotOwnerInternalId)) continue;
            if (!tomeFeatureNamesById.TryGetValue(node.SlotOwnerInternalId, out var featureName)) continue;
            map[power.InternalId] = featureName;
        }
        return map;
    }

    private void HandleSessionChanged()
    {
        if (_usedPowersSessionVersion != SessionService.SessionVersion)
        {
            _usedPowers.Clear();
            _usedPowersSessionVersion = SessionService.SessionVersion;
        }
        _ = InvokeAsync(StateHasChanged);
    }

    private static int GetPrintFillerCount(int powerCount, int pendingCount)
    {
        const int columns = 4;
        int total = powerCount + pendingCount;
        if (total <= 0)
            return columns;

        int remainder = total % columns;
        return remainder == 0 ? 0 : columns - remainder;
    }

    public async ValueTask DisposeAsync()
    {
        SessionService.Changed -= HandleSessionChanged;

        if (_bodyClassApplied)
        {
            try
            {
                await JS.InvokeVoidAsync("charm.setBodyClass", "view-print-cards", false);
            }
            catch (JSDisconnectedException)
            {
            }
        }
    }

