                            </div>
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center">
                                    <span class="material-symbols-outlined text-primary text-sm">pending_actions</span>
                                </div>
                                <span class="text-xs font-label uppercase tracking-wider font-bold">@pendingChoices.Count open power slots</span>
                            </div>
